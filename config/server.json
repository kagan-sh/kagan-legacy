{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.kagan-sh/kagan",
  "title": "Kagan",
  "description": "Supervision layer for AI coding agents — isolate work, verify it before review, ship on your terms",
  "websiteUrl": "https://kagan.sh",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/kagan-sh/kagan/main/docs/assets/favicon.svg",
      "mimeType": "image/svg+xml"
    }
  ],
  "repository": {
    "url": "https://github.com/kagan-sh/kagan",
    "source": "github"
  },
  "version": "0.19.0-beta.38",
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "kagan",
      "version": "0.19.0-beta.38",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "KAGAN_DATA_DIR",
          "description": "Custom path for the Kagan ledger directory",
          "format": "filepath",
          "secret": false
        }
      ]
    }
  ]
}
