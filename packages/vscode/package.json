{
  "name": "kagan-vscode",
  "displayName": "Kagan",
  "description": "AI-powered Kanban board for orchestrating coding agents — manage tasks, stream agent output, review diffs, and merge from VS Code",
  "version": "0.18.0",
  "publisher": "kagan",
  "license": "MIT",
  "icon": "media/kagan-icon.png",
  "homepage": "https://kagan.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/kagan-sh/kagan",
    "directory": "packages/vscode"
  },
  "bugs": {
    "url": "https://github.com/kagan-sh/kagan/issues"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "SCM Providers",
    "Chat"
  ],
  "keywords": [
    "kanban",
    "ai",
    "agents",
    "claude",
    "orchestrator",
    "code-review",
    "task-management"
  ],
  "galleryBanner": {
    "color": "#0a0a0a",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.kagan/attach_context.json"
  ],
  "contributes": {
    "colors": [
      {
        "id": "kagan.primary",
        "description": "Kagan primary accent — aged amber phosphor",
        "defaults": {
          "dark": "#d4a84b",
          "light": "#b89154",
          "highContrast": "#d4a84b"
        }
      },
      {
        "id": "kagan.railRunning",
        "description": "Kagan status rail — running / in progress",
        "defaults": {
          "dark": "#3fb58e",
          "light": "#1a8563",
          "highContrast": "#3fb58e"
        }
      },
      {
        "id": "kagan.railWarning",
        "description": "Kagan status rail — warning",
        "defaults": {
          "dark": "#e6c07b",
          "light": "#a87b25",
          "highContrast": "#e6c07b"
        }
      },
      {
        "id": "kagan.railReview",
        "description": "Kagan status rail — review",
        "defaults": {
          "dark": "#c27c4e",
          "light": "#a8653a",
          "highContrast": "#c27c4e"
        }
      },
      {
        "id": "kagan.railIdle",
        "description": "Kagan status rail — idle / backlog",
        "defaults": {
          "dark": "#777777",
          "light": "#8a7f72",
          "highContrast": "#777777"
        }
      },
      {
        "id": "kagan.modeAuto",
        "description": "Kagan execution mode badge — AUTO",
        "defaults": {
          "dark": "#d4a84b",
          "light": "#b89154",
          "highContrast": "#d4a84b"
        }
      },
      {
        "id": "kagan.modePair",
        "description": "Kagan execution mode badge — PAIR",
        "defaults": {
          "dark": "#6fa3d4",
          "light": "#6fa3d4",
          "highContrast": "#6fa3d4"
        }
      }
    ],
    "chatParticipants": [
      {
        "id": "kagan.agent",
        "fullName": "Kagan",
        "name": "kagan",
        "description": "Chat with Kagan sessions and check board status",
        "isSticky": true,
        "commands": [
          {
            "name": "status",
            "description": "Show board status and running tasks"
          },
          {
            "name": "sessions",
            "description": "List all active sessions"
          },
          {
            "name": "switch",
            "description": "Switch to a session by ID"
          },
          {
            "name": "stop",
            "description": "Stop the selected session"
          },
          {
            "name": "close",
            "description": "Close the selected session"
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kagan",
          "title": "Kagan",
          "icon": "media/kagan.svg"
        }
      ]
    },
    "views": {
      "kagan": [
        {
          "id": "kagan.board",
          "name": "Board"
        },
        {
          "id": "kagan.agents",
          "name": "Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "kagan.connect",
        "title": "Connect to server",
        "category": "Kagan"
      },
      {
        "command": "kagan.disconnect",
        "title": "Disconnect",
        "category": "Kagan"
      },
      {
        "command": "kagan.board.refresh",
        "title": "Refresh board",
        "category": "Kagan",
        "icon": "$(refresh)"
      },
      {
        "command": "kagan.task.create",
        "title": "Create task",
        "category": "Kagan",
        "icon": "$(add)"
      },
      {
        "command": "kagan.task.run",
        "title": "Run task",
        "category": "Kagan",
        "icon": "$(play)"
      },
      {
        "command": "kagan.task.cancel",
        "title": "Cancel task",
        "category": "Kagan",
        "icon": "$(debug-stop)"
      },
      {
        "command": "kagan.task.open",
        "title": "Open task",
        "category": "Kagan"
      },
      {
        "command": "kagan.task.delete",
        "title": "Delete task",
        "category": "Kagan",
        "icon": "$(trash)"
      },
      {
        "command": "kagan.task.move",
        "title": "Move task to column",
        "category": "Kagan"
      },
      {
        "command": "kagan.task.edit",
        "title": "Edit task",
        "category": "Kagan",
        "icon": "$(edit)"
      },
      {
        "command": "kagan.task.diff",
        "title": "View task diff",
        "category": "Kagan",
        "icon": "$(diff)"
      },
      {
        "command": "kagan.review.approve",
        "title": "Approve",
        "category": "Kagan Review",
        "icon": "$(check)"
      },
      {
        "command": "kagan.review.reject",
        "title": "Reject",
        "category": "Kagan Review",
        "icon": "$(close)"
      },
      {
        "command": "kagan.review.merge",
        "title": "Merge",
        "category": "Kagan Review",
        "icon": "$(git-merge)"
      },
      {
        "command": "kagan.events.show",
        "title": "Show agent log",
        "category": "Kagan",
        "icon": "$(output)"
      },
      {
        "command": "kagan.terminal.attach",
        "title": "Attach to agent terminal",
        "category": "Kagan",
        "icon": "$(terminal)"
      },
      {
        "command": "kagan.chat.open",
        "title": "Open session in chat",
        "category": "Kagan",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "kagan.settings.agentBackend",
        "title": "Set default agent backend",
        "category": "Kagan Settings"
      },
      {
        "command": "kagan.settings.reviewStrictness",
        "title": "Set review strictness",
        "category": "Kagan Settings"
      },
      {
        "command": "kagan.settings.planningDepth",
        "title": "Set planning depth",
        "category": "Kagan Settings"
      },
      {
        "command": "kagan.analytics.show",
        "title": "Show analytics summary",
        "category": "Kagan"
      },
      {
        "command": "kagan.analytics.export",
        "title": "Export analytics to JSON",
        "category": "Kagan"
      },
      {
        "command": "kagan.github.import",
        "title": "Import from GitHub",
        "category": "Kagan",
        "icon": "$(cloud-download)"
      },
      {
        "command": "kagan.openInstallDocs",
        "title": "Install Kagan CLI",
        "category": "Kagan",
        "icon": "$(question)"
      },
      {
        "command": "kagan.switchSession",
        "title": "Switch to session",
        "category": "Kagan"
      },
      {
        "command": "kagan.stopSession",
        "title": "Stop session",
        "category": "Kagan",
        "icon": "$(debug-stop)"
      },
      {
        "command": "kagan.closeSession",
        "title": "Close session",
        "category": "Kagan",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "kagan.newGeneralSession",
        "title": "New general session",
        "category": "Kagan",
        "icon": "$(add)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "kagan.board.refresh",
          "when": "view == kagan.board && kagan.connected",
          "group": "navigation"
        },
        {
          "command": "kagan.task.create",
          "when": "view == kagan.board && kagan.connected",
          "group": "navigation"
        },
        {
          "command": "kagan.github.import",
          "when": "view == kagan.board && kagan.connected",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "kagan.task.run",
          "when": "view == kagan.board && viewItem =~ /^task\\.BACKLOG$/",
          "group": "inline@1"
        },
        {
          "command": "kagan.task.cancel",
          "when": "view == kagan.board && viewItem == task.IN_PROGRESS",
          "group": "inline@2"
        },
        {
          "command": "kagan.chat.open",
          "when": "view == kagan.board && viewItem =~ /^task\\.(IN_PROGRESS|REVIEW)$/",
          "group": "inline@3"
        },
        {
          "command": "kagan.task.diff",
          "when": "view == kagan.board && viewItem =~ /^task\\.(REVIEW|DONE)$/",
          "group": "inline@1"
        },
        {
          "command": "kagan.task.edit",
          "when": "view == kagan.board && viewItem =~ /^task\\./",
          "group": "1_modification"
        },
        {
          "command": "kagan.task.move",
          "when": "view == kagan.board && viewItem =~ /^task\\./",
          "group": "1_modification"
        },
        {
          "command": "kagan.task.delete",
          "when": "view == kagan.board && viewItem =~ /^task\\./",
          "group": "9_delete"
        },
        {
          "command": "kagan.review.approve",
          "when": "view == kagan.board && viewItem == task.REVIEW",
          "group": "2_review@1"
        },
        {
          "command": "kagan.review.reject",
          "when": "view == kagan.board && viewItem == task.REVIEW",
          "group": "2_review@2"
        },
        {
          "command": "kagan.review.merge",
          "when": "view == kagan.board && viewItem == task.REVIEW",
          "group": "2_review@3"
        },
        {
          "command": "kagan.events.show",
          "when": "view == kagan.board && viewItem =~ /^task\\.(IN_PROGRESS|REVIEW|DONE)$/",
          "group": "3_observe"
        },
        {
          "command": "kagan.terminal.attach",
          "when": "view == kagan.board && viewItem == task.IN_PROGRESS",
          "group": "3_observe"
        },
        {
          "command": "kagan.stopSession",
          "when": "view == kagan.agents && viewItem =~ /stop_1/",
          "group": "1_session@1"
        },
        {
          "command": "kagan.closeSession",
          "when": "view == kagan.agents && viewItem =~ /close_1/",
          "group": "1_session@2"
        }
      ],
      "commandPalette": [
        {
          "command": "kagan.connect"
        },
        {
          "command": "kagan.disconnect",
          "when": "kagan.connected"
        },
        {
          "command": "kagan.board.refresh",
          "when": "kagan.connected"
        },
        {
          "command": "kagan.task.create",
          "when": "kagan.connected"
        },
        {
          "command": "kagan.task.open",
          "when": "kagan.connected"
        },
        {
          "command": "kagan.events.show",
          "when": "kagan.connected"
        },
        {
          "command": "kagan.terminal.attach",
          "when": "kagan.connected"
        },
        {
          "command": "kagan.chat.open",
          "when": "kagan.connected"
        },
        {
          "command": "kagan.settings.agentBackend",
          "when": "kagan.connected"
        },
        {
          "command": "kagan.settings.reviewStrictness",
          "when": "kagan.connected"
        },
        {
          "command": "kagan.settings.planningDepth",
          "when": "kagan.connected"
        },
        {
          "command": "kagan.analytics.show",
          "when": "kagan.connected"
        },
        {
          "command": "kagan.analytics.export",
          "when": "kagan.connected"
        },
        {
          "command": "kagan.github.import",
          "when": "kagan.connected"
        },
        {
          "command": "kagan.openInstallDocs"
        },
        {
          "command": "kagan.stopSession",
          "when": "kagan.connected"
        },
        {
          "command": "kagan.closeSession",
          "when": "kagan.connected"
        },
        {
          "command": "kagan.newGeneralSession",
          "when": "kagan.connected"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "kagan.board",
        "contents": "Not connected to a Kagan server.\n[Connect](command:kagan.connect)\n\nKagan CLI not found on PATH?\n[Install Kagan CLI](command:kagan.openInstallDocs)",
        "when": "!kagan.connected"
      }
    ],
    "configuration": {
      "title": "Kagan",
      "properties": {
        "kagan.serverUrl": {
          "type": "string",
          "default": "localhost:8765",
          "description": "Kagan server host:port (protocol is controlled separately via kagan.protocol)"
        },
        "kagan.protocol": {
          "type": "string",
          "enum": [
            "http",
            "https"
          ],
          "default": "http",
          "description": "Protocol for connecting to Kagan server (http or https)"
        },
        "kagan.authToken": {
          "type": "string",
          "default": "",
          "description": "Bearer token for authentication to Kagan server (sent as Authorization: Bearer <token>)",
          "markdownDescription": "Bearer token for authentication to Kagan server (sent as `Authorization: Bearer <token>`)"
        },
        "kagan.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect on startup only when the workspace contains Kagan context"
        },
        "kagan.autoStartServer": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start `kagan serve` for explicit connects or workspaces with Kagan context when serverUrl points to localhost and no Kagan server is running"
        },
        "kagan.serverCommand": {
          "type": "string",
          "default": "kagan",
          "description": "Command used to start the local Kagan server automatically; the extension runs `<command> serve`"
        }
      }
    }
  },
  "scripts": {
    "build": "pnpm run check-types && node esbuild.js --production",
    "compile": "pnpm run check-types && node esbuild.js",
    "check-types": "tsc --noEmit",
    "check-types:test": "tsc --noEmit -p tsconfig.test.json",
    "build:test": "tsc -p tsconfig.test.json",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "vitest run",
    "test:integration": "pnpm run compile && pnpm run build:test && vscode-test",
    "test:e2e": "pnpm run compile && wdio run ./test/wdio.conf.ts",
    "test:check": "pnpm run check-types && pnpm run check-types:test && pnpm run test:unit",
    "vscode:prepublish": "pnpm run package",
    "package": "pnpm run check-types && node esbuild.js --production",
    "vsix": "pnpm exec vsce package --allow-missing-repository"
  },
  "dependencies": {
    "@kagan/shared-api-client": "workspace:*"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.96.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "esbuild": "^0.28.0",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "ovsx": "^0.10.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wdio-vscode-service": "^6.1.4",
    "webdriverio": "^9.27.0"
  }
}
