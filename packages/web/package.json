{
  "name": "kagan-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b tsconfig.app.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "playwright test e2e/a11y.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "rm -rf .nyc_output coverage && E2E_COVERAGE=1 playwright test && nyc report",
    "check:raw-colors": "node scripts/check_raw_colors.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@hookform/resolvers": "^5.0.1",
    "@kagan/shared-api-client": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "^3.4.0",
    "jotai": "^2.19.1",
    "lucide-react": "^1.8.0",
    "marked": "^18.0.2",
    "monaco-editor": "^0.55.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-resizable-panels": "^4.10.0",
    "react-router": "^7.15.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "nyc": "^18.0.0",
    "shadcn": "^4.3.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-istanbul": "^8.0.0",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^4.1.4"
  }
}
