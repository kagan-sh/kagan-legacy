/* Kagan TUI Styles - Khagan Night Theme */
/* Uses Textual design tokens for theme compatibility */

/* =============================================================================
   DESIGN TOKENS - Premium Kagan Night Theme
   ============================================================================= */

/* Spacing Scale (consistent rhythm) */
$space-xs: 0;
$space-sm: 1;
$space-md: 2;
$space-lg: 3;
$space-xl: 4;

/* Semantic Status Colors */
$status-running: $secondary;      /* Green - active/in-progress (secondary = jade green) */
$status-success: $success;        /* Green - passed/complete */
$status-warning: $warning;        /* Yellow - needs attention */
$status-error: $error;            /* Red - failed/blocked */
$status-idle: $text-muted;        /* Gray - inactive */

/* State Opacities */
$opacity-disabled: 40%;
$opacity-hover: 10%;
$opacity-focus: 20%;

/* =============================================================================
   BADGE SYSTEM
   ============================================================================= */

/* Badge Base */
.badge { padding: 0 1; height: 1; min-width: 3; }
.badge-sm { padding: 0; min-width: 1; }
.badge-primary { background: $primary; color: $background; }
.badge-success { background: $success; color: $background; }
.badge-warning { background: $warning; color: $background; }
.badge-error { background: $error; color: $text; }
.badge-muted { background: $surface; color: $text-muted; }

/* =============================================================================
   BUTTON VARIANTS
   ============================================================================= */

.btn-icon { min-width: 3; padding: 0 1; }
.btn-compact { min-width: auto; padding: 0 1; }
.btn-wide { min-width: 20; }

/* =============================================================================
   CSS VARIABLES
   ============================================================================= */

/* Priority colors - semantic aliases for consistency */
$priority-high: $error;
$priority-high-text: $background;
$priority-medium: $warning;
$priority-medium-text: $background;
$priority-low: $border;
$priority-low-text: $text-muted;
/* Kanban board background token (must be available across all themes). */
$kanban-background: $background;

/* Status badge text colors - use dark text for visibility on colored backgrounds */
$success-text: $background;
$error-text: $background;
$warning-text: $background;

/* Common spacing */
$modal-padding: 1 2;
$card-margin: 0 0 1 0;

/* Common border styles */
$border-standard: solid $border;
$border-focused: solid $primary;
$border-modal: round $primary;

/* =============================================================================
   GLOBAL STYLES
   ============================================================================= */

/* Global app styles */
Screen {
    background: $background;
}

/* Compact checkbox baseline across the TUI (text-first, terminal-native). */
Checkbox.-textual-compact {
    border: none !important;
    padding: 0;
    min-height: 1;
    background: transparent;
}

Checkbox.-textual-compact > .toggle--button {
    color: $text-muted;
    background: $surface;
}

Checkbox.-textual-compact.-on > .toggle--button {
    color: $success;
    background: $surface;
}

Checkbox.-textual-compact > .toggle--label {
    color: $text;
}

Checkbox.-textual-compact:focus {
    border: none !important;
    background: $primary 12%;
}

Checkbox.-textual-compact:focus > .toggle--label {
    color: $text;
    background: transparent;
    text-style: bold;
}

/* Compact select baseline across the TUI (one-line current value, terminal-like). */
Select.-textual-compact {
    min-height: 1;
    border: none !important;
    background: transparent;
}

Select.-textual-compact > SelectCurrent {
    border: none !important;
    background: transparent;
    padding: 0 1 0 0;
}

Select.-textual-compact > SelectCurrent .arrow {
    color: $text-muted;
}

Select.-textual-compact:focus > SelectCurrent {
    border: none !important;
    background: $primary 12%;
}

Select.-textual-compact:focus > SelectCurrent > Static#label {
    text-style: bold;
}

/* =============================================================================
   HEADER & FOOTER
   ============================================================================= */

/* Custom KaganHeader styles - Khagan Night theme */
KaganHeader {
    dock: top;
    width: 100%;
    height: 3;
    background: $background;
    color: $text-muted;
    layout: horizontal;
    padding: 1 1 0 1;
    align: left middle;
    border-bottom: solid $panel;
}

KaganHeader .header-logo {
    width: auto;
    color: $text-muted;
    text-style: bold;
    text-opacity: 100%;
    padding-right: 1;
}

KaganHeader .header-logo.logo-connected {
    color: $text-muted;
    text-opacity: 100%;
}

KaganHeader .header-logo.logo-disconnected {
    color: $text-disabled;
    text-opacity: 100%;
}

KaganHeader .header-title {
    width: auto;
    color: $text;
    text-style: bold;
    text-opacity: 100%;
}

KaganHeader .header-repo {
    width: auto;
    color: $text-disabled;
    text-opacity: 100%;
}

KaganHeader .header-version {
    width: auto;
    color: $text-muted;
    padding-left: 1;
}

KaganHeader .header-spacer {
    width: 1fr;
}

KaganHeader .header-branch {
    width: auto;
    color: $text-disabled;
    text-opacity: 100%;
    padding-right: 2;
}

KaganHeader .header-sessions {
    width: auto;
    color: $text-disabled;
    text-opacity: 100%;
    padding-right: 2;
}

KaganHeader .header-github-status {
    width: auto;
    padding-right: 2;
    color: $text-disabled;
    text-opacity: 100%;
}

KaganHeader .header-github-status.github-synced {
    color: $success;
    text-opacity: 100%;
}

KaganHeader .header-github-status.github-pending {
    color: $warning;
    text-opacity: 100%;
}

KaganHeader .header-agent {
    width: auto;
    color: $text-disabled;
    text-style: bold;
    text-opacity: 100%;
    padding-right: 2;
}

KaganHeader .core-status {
    width: auto;
    padding-right: 2;
}

KaganHeader .header-stats {
    width: auto;
    color: $text-disabled;
    text-opacity: 100%;
}

/* Dim separator characters between header sections */
KaganHeader .header-separator {
    width: auto;
    color: $text-disabled;
    text-opacity: 100%;
    padding: 0 1;
}

/* Footer styles - subtle appearance */
Footer {
    background: $surface;
    border-top: solid $border;
}

FooterKey > .footer-key--key {
    background: transparent;
    color: $primary;
    text-style: bold;
}

FooterKey > .footer-key--description {
    color: $text-muted;
    text-opacity: 100%;
}

/* Modal Footer - dock to bottom of screen */
ModalScreen Footer {
    dock: bottom;
}

/* =============================================================================
   SHARED MODAL HINTS (keyboard-first popups)
   ============================================================================= */

/* Centered, dimmed keyboard-controls copy for popup/modals. */
.modal-keyboard-hint,
.modal-action-hint,
ConfirmModal .confirm-hint,
PairInstructionsModal .tmux-hint,
ReviewModal .hint-label,
RejectionInputModal .hint-label {
    width: 100%;
    text-align: center;
    color: $text-disabled;
    text-opacity: 100%;
}

/* Bottom-docked action hint strip for keyboard-only modal actions. */
.modal-action-hint-row {
    dock: bottom;
    width: 100%;
    height: auto;
    align: center middle;
    border-top: solid $border;
    background: $surface;
    margin-top: 1;
    padding: 1 1 0 1;
}

/* Single centered action-hint label. */
.modal-action-hint-row .modal-action-hint {
    width: 100%;
    text-align: center;
}

/* Optional three-slot layout when hints are split by left/center/right. */
.modal-action-hint-row .modal-action-hint-start,
.modal-action-hint-row .modal-action-hint-center,
.modal-action-hint-row .modal-action-hint-end {
    width: 1fr;
    color: $text-disabled;
    text-opacity: 100%;
}

.modal-action-hint-row .modal-action-hint-start {
    text-align: left;
}

.modal-action-hint-row .modal-action-hint-center {
    text-align: center;
}

.modal-action-hint-row .modal-action-hint-end {
    text-align: right;
}

.modal-action-hint-key {
    color: $secondary;
}

.modal-action-hint-separator {
    color: $border;
}

/* =============================================================================
   KANBAN BOARD
   ============================================================================= */

/* Kanban board styles */
.board-container {
    width: 100%;
    height: 1fr;
    padding: 0;
    background: $kanban-background;
}

.board {
    width: 100%;
    height: 100%;
    background: $kanban-background;
}

/* Column styles - flush layout with border separators */
KanbanColumn {
    width: 1fr;
    height: 100%;
    border-right: solid $border;
    padding: 0;
    margin: 0;
    background: $surface;
}

/* No right border on last column */
KanbanColumn:last-child {
    border-right: none;
}

KanbanColumn .column-header {
    width: 100%;
    height: 3;
    padding: 0 1;
    align: center middle;
    border-bottom: solid $primary;
}

KanbanColumn .column-header-text {
    text-style: bold;
    color: $text;
    width: auto;
    text-align: center;
}

KanbanColumn .column-count {
    color: $text-muted;
}

KanbanColumn .column-content {
    width: 100%;
    height: 1fr;
    padding: 0;
}

KanbanColumn .column-empty {
    width: 100%;
    height: 1fr;
    align: center middle;
}

KanbanColumn .empty-message {
    width: 100%;
    text-align: center;
    color: $text-disabled;
    text-style: italic;
    padding: 2;
}

/* =============================================================================
   TASK CARDS
   ============================================================================= */

/* Card styles - bottom-border only, flush within column */
TaskCard {
    width: 100%;
    height: 4;
    margin: 0;
    padding: 0;
    border-bottom: solid $border;
    background: $surface;
    color: $text;
}

TaskCard:focus {
    border-bottom: solid $primary;
    background: $panel;
}

TaskCard:hover {
    background: $panel;
}

/* ============================================
   CARD CONTENT STYLES
   ============================================ */

TaskCard .card-row {
    width: 100%;
    height: 1;
    padding: 0 1;
}

TaskCard .card-rail {
    width: 1;
    text-style: bold;
    color: $border;
}

TaskCard .card-rail.rail-normal {
    color: $border;
}

TaskCard .card-rail.rail-running {
    color: $secondary;
}

TaskCard .card-rail.rail-warning {
    color: $warning;
}

TaskCard .card-rail.rail-error {
    color: $error;
}

TaskCard .card-rail.rail-success {
    color: $success;
}

TaskCard:focus .card-rail.rail-normal {
    color: $primary;
}

TaskCard .card-title {
    width: 1fr;
    height: 1;
    text-style: bold;
    color: $text;
}

TaskCard .card-desc {
    width: 1fr;
    height: 1;
    color: $text-muted;
}

TaskCard .card-desc-empty {
    color: $text-disabled;
    text-style: italic;
}

TaskCard .card-badge-row {
    width: 100%;
    height: 1;
}

/* Right-aligned card ID (muted) */
TaskCard .card-id {
    width: auto;
    height: 1;
    color: $text-muted;
}

/* Branch badge - shows git branch name */
TaskCard .card-branch {
    width: auto;
    height: 1;
    color: $text-muted;
    text-style: italic;
    margin-left: 1;
}

/* GitHub context badges (issue #, PR #) */
TaskCard .card-badge-gh {
    background: $panel;
    color: $text;
}

TaskCard .card-badge-gh-issue {
    background: $surface;
    color: $text-muted;
}

TaskCard .card-badge-gh-pr {
    background: $success;
    color: $success-text;
    text-style: bold;
}

/* Spacer pushes priority badge right */
TaskCard .card-spacer {
    width: 1fr;
    height: 1;
}

TaskCard .card-badge {
    height: 1;
    padding: 0 1;
    margin-right: 1;
    background: $surface;
    color: $text-muted;
}

TaskCard .card-badge-type {
    background: $secondary;
    color: $background;
}

TaskCard .card-badge-backend {
    background: $panel;
    color: $text;
}

TaskCard .card-badge-priority.priority-high {
    background: $priority-high;
    color: $priority-high-text;
}

TaskCard .card-badge-priority.priority-medium {
    background: $priority-medium;
    color: $priority-medium-text;
}

TaskCard .card-badge-priority.priority-low {
    background: $priority-low;
    color: $priority-low-text;
}

TaskCard .card-review {
    width: 100%;
    height: 1;
    color: $text;
}

TaskCard .card-checks {
    width: 100%;
    height: 1;
    color: $success;
}

/* Review state colors for checks line */
TaskCard .card-checks.passed {
    color: $success;
}

TaskCard .card-checks.failed {
    color: $error;
}

TaskCard .card-checks.pending {
    color: $warning;
}

TaskCard .card-readiness {
    width: 100%;
    height: 1;
    color: $text-muted;
}

TaskCard .card-readiness.readiness-ready {
    color: $success;
}

TaskCard .card-readiness.readiness-risk {
    color: $warning;
}

TaskCard .card-readiness.readiness-blocked {
    color: $error;
}

/* Card status indicators */
TaskCard .card-indicator {
    width: 2;
    height: 1;
    text-style: bold;
}

TaskCard .indicator-running { color: $status-running; }
TaskCard .indicator-idle    { color: $status-idle; }
TaskCard .indicator-reviewing { color: $accent; }
TaskCard .indicator-blocked { color: $status-error; }
TaskCard .indicator-passed  { color: $status-success; }
TaskCard .indicator-failed  { color: $status-error; }

/* =============================================================================
   MODALS
   ============================================================================= */

/* Task details modal */
TaskDetailsModal {
    align: center middle;
}

TaskDetailsModal > Vertical,
TaskDetailsModal #task-details-container {
    width: 80;
    max-height: 80%;
    border: round $primary;
    background: $surface;
    padding: 1 2;
    overflow-y: auto;
}

TaskDetailsModal .modal-title {
    text-align: center;
    text-style: bold;
    width: 100%;
    padding-bottom: 1;
    color: $primary;
}

TaskDetailsModal Rule {
    margin: 1 0;
    color: $border;
}

TaskDetailsModal .badge-row {
    width: 100%;
    height: auto;
}

TaskDetailsModal .badge {
    padding: 0 1;
    margin-right: 1;
}

TaskDetailsModal .badge-priority-high {
    background: $priority-high;
    color: $priority-high-text;
}

TaskDetailsModal .badge-priority-medium {
    background: $priority-medium;
    color: $priority-medium-text;
}

TaskDetailsModal .badge-priority-low {
    background: $priority-low;
    color: $priority-low-text;
}

TaskDetailsModal .badge-status {
    background: $primary;
    color: $background;
}

TaskDetailsModal .badge-type {
    background: $secondary;
    color: $background;
}

.badge-agent {
    background: $secondary;
    color: $background;
}

.badge-model {
    background: $accent;
    color: $background;
}

TaskDetailsModal .section-title {
    text-style: bold;
    color: $text-muted;
    width: auto;
}

TaskDetailsModal .task-title {
    text-style: bold;
    padding: 0 1;
    color: $text;
    background: $background;
}

TaskDetailsModal .description-header {
    width: 100%;
    height: 1;
}

TaskDetailsModal .header-spacer {
    width: 1fr;
}

TaskDetailsModal .expand-hint {
    width: auto;
    color: $primary;
}

TaskDetailsModal .task-description {
    padding: 1;
    background: $background;
    min-height: 3;
    max-height: 10;
    height: auto;
    color: $text;
    overflow-y: auto;
}

/* Acceptance criteria section */
TaskDetailsModal .acceptance-criteria-section {
    width: 100%;
    height: auto;
    padding: 0 1;
}

TaskDetailsModal .ac-item {
    color: $text;
    padding-left: 1;
}

TaskDetailsModal #ac-input {
    height: 6;
    min-height: 4;
}

/* Review results section */
TaskDetailsModal .review-results-section {
    width: 100%;
    height: auto;
    padding: 0 1;
}

TaskDetailsModal .review-status-row {
    width: 100%;
    height: auto;
    margin-bottom: 1;
}

TaskDetailsModal .review-label {
    padding-left: 2;
    color: $text-muted;
}

TaskDetailsModal .review-summary-text {
    padding: 1;
    background: $surface;
    color: $text;
    width: 100%;
    height: auto;
}

TaskDetailsModal .merge-error-text {
    padding: 1;
    color: $error;
}

TaskDetailsModal .merge-help-text {
    padding: 1;
    color: $warning;
}

TaskDetailsModal .badge-checks-passed {
    background: $success;
    color: $success-text;
}

TaskDetailsModal .badge-checks-failed {
    background: $error;
    color: $error-text;
}

TaskDetailsModal .badge-checks-pending {
    background: $warning;
    color: $warning-text;
}

TaskDetailsModal .badge-readiness-ready {
    background: $success;
    color: $success-text;
}

TaskDetailsModal .badge-readiness-risk {
    background: $warning;
    color: $warning-text;
}

TaskDetailsModal .badge-readiness-blocked {
    background: $error;
    color: $error-text;
}

TaskDetailsModal .parallel-work-section {
    width: 100%;
    height: auto;
    padding: 0 1;
}

TaskDetailsModal #parallel-work-content {
    color: $text;
    padding: 1;
}

TaskDetailsModal .audit-section {
    width: 100%;
    height: auto;
    padding: 0 1;
}

TaskDetailsModal #audit-content {
    color: $text-muted;
    padding: 1;
}

/* Resume Context section (IN_PROGRESS / REVIEW tasks) */
TaskDetailsModal .resume-context-section {
    width: 100%;
    height: auto;
    padding: 0 1;
}

TaskDetailsModal .resume-context-scroll {
    max-height: 6;
    height: auto;
    background: $background;
}

TaskDetailsModal #resume-context-content {
    color: $text-muted;
    padding: 0 1;
    height: auto;
}

/* GitHub context section */
TaskDetailsModal .github-section {
    width: 100%;
    height: auto;
    padding: 0 1;
}

TaskDetailsModal #github-context-content {
    color: $text-muted;
    padding: 0 1;
    height: auto;
}

TaskDetailsModal .meta-row {
    width: 100%;
    height: auto;
}

TaskDetailsModal .task-meta {
    color: $text-muted;
    width: auto;
}

TaskDetailsModal .meta-separator {
    width: auto;
    color: $border;
}

TaskDetailsModal .button-row {
    width: 100%;
    height: auto;
    padding-top: 1;
    align: center middle;
}

TaskDetailsModal Button {
    margin: 0 1;
}

/* Edit mode styles for TaskDetailsModal */
TaskDetailsModal .edit-fields {
    display: none;
}

TaskDetailsModal.editing .edit-fields {
    display: block;
}

TaskDetailsModal .view-only {
    display: block;
}

TaskDetailsModal.editing .view-only {
    display: none;
}

/* Status field only shown in create mode during editing */
TaskDetailsModal #status-field {
    display: none;
}

TaskDetailsModal.editing.create-mode #status-field {
    display: block;
}

/* Meta row hidden during editing */
TaskDetailsModal.editing #meta-row {
    display: none;
}

TaskDetailsModal .form-field {
    width: 100%;
    height: auto;
    margin-bottom: 1;
}

TaskDetailsModal .form-label {
    width: auto;
    height: 1;
    padding-bottom: 0;
    color: $text;
    text-style: bold;
}

TaskDetailsModal .form-field:focus-within .form-label {
    color: $secondary;
}

TaskDetailsModal Input {
    width: 100%;
    background: $background;
    color: $text;
    border: solid $border;
}

TaskDetailsModal Input:focus {
    border: solid $primary;
    background: $surface;
}

TaskDetailsModal TextArea {
    width: 100%;
    height: 10;
    min-height: 6;
    background: $background;
    color: $text;
    border: solid $border;
}

TaskDetailsModal TextArea:focus {
    border: solid $primary;
    background: $surface;
}

TaskDetailsModal Select {
    width: 100%;
}

TaskDetailsModal Select:focus > SelectCurrent {
    border: none !important;
    background: $primary 12%;
}

/* Horizontal field row for Priority/Agent in edit mode */
TaskDetailsModal .field-row {
    width: 100%;
    height: auto;
    margin-bottom: 1;
}

TaskDetailsModal .field-half {
    width: 1fr;
    margin-right: 1;
}

TaskDetailsModal .field-half:last-child {
    margin-right: 0;
}

TaskDetailsModal .field-third {
    width: 1fr;
    margin-right: 1;
}

TaskDetailsModal .field-third:last-child {
    margin-right: 0;
}

/* Base branch section for view and edit modes */
TaskDetailsModal .base-branch-section {
    width: 100%;
    height: auto;
    margin-bottom: 1;
}

TaskDetailsModal .base-branch-section.view-only {
    height: auto;
}

TaskDetailsModal .base-branch-section .form-label {
    color: $text-muted;
}

/* BaseBranchInput styling */
BaseBranchInput {
    width: 100%;
    background: $background;
    color: $text;
    border: solid $border;
}

BaseBranchInput:focus {
    border: solid $primary;
}

/* Full-screen description editor modal */
DescriptionEditorModal {
    align: center middle;
}

DescriptionEditorModal #description-editor-container {
    width: 90%;
    height: 90%;
    border: round $primary;
    background: $surface;
    padding: 0;
}

DescriptionEditorModal #description-editor-header {
    width: 100%;
    height: 3;
    padding: 1 2;
    background: $panel;
}

DescriptionEditorModal #editor-title {
    width: auto;
    text-style: bold;
    color: $primary;
}

DescriptionEditorModal #header-spacer {
    width: 1fr;
}

DescriptionEditorModal #editor-hint {
    width: auto;
    color: $primary;
}

DescriptionEditorModal #description-textarea {
    width: 100%;
    height: 1fr;
    background: $background;
    color: $text;
    border: none;
    padding: 0;
}

DescriptionEditorModal #description-textarea:focus {
    border: none;
}

DescriptionEditorModal #description-editor-status {
    width: 100%;
    height: 1;
    padding: 0 2;
    background: $panel;
}

DescriptionEditorModal #cursor-position {
    width: auto;
    color: $text-muted;
}

DescriptionEditorModal #status-spacer {
    width: 1fr;
}

DescriptionEditorModal #line-count {
    width: auto;
    color: $text-muted;
}

/* Empty state */
.empty-state {
    width: 100%;
    height: 100%;
    align: center middle;
}

.empty-message {
    text-align: center;
    color: $text-muted;
    padding: 2;
}

/* =============================================================================
   SCREENS
   ============================================================================= */

/* KanbanScreen styles */
KanbanScreen {
    layout: vertical;
    background: $background;
    layers: base overlay;
}

KanbanScreen .size-warning {
    width: 100%;
    height: 100%;
    align: center middle;
    background: $surface;
    display: none;
}

KanbanScreen .size-warning-text {
    text-align: center;
    color: $warning;
    text-style: bold;
}

KanbanScreen.too-small .board-container {
    display: none;
}

KanbanScreen.too-small .size-warning {
    display: block;
}

/* ConfirmModal styles */
ConfirmModal {
    align: center middle;
}

ConfirmModal > Container {
    width: 50;
    height: auto;
    border: round $error;
    background: $surface;
    padding: 2 3;
}

ConfirmModal .confirm-title {
    text-style: bold;
    text-align: center;
    padding-bottom: 1;
    color: $error;
}

ConfirmModal .confirm-message {
    text-align: center;
    padding-bottom: 1;
    color: $text;
}

ConfirmModal .confirm-hint {
    padding-top: 1;
}

/* =============================================================================
   BASE BRANCH MODAL
   ============================================================================= */

BaseBranchModal {
    align: center middle;
}

#branch-modal-container {
    width: 60;
    height: auto;
    border: round $primary;
    background: $surface;
    padding: 2 3;
}

#branch-modal-title {
    text-style: bold;
    text-align: center;
    width: 100%;
    padding-bottom: 1;
    color: $primary;
}

#branch-modal-description {
    text-align: center;
    color: $text-muted;
    padding-bottom: 1;
}

BaseBranchModal #branch-select {
    width: 100%;
    margin-bottom: 1;
}

BaseBranchModal #branch-custom-input {
    width: 100%;
    margin-bottom: 1;
    background: $background;
    border: solid $border;
}

BaseBranchModal #branch-custom-input:focus {
    border: solid $primary;
}

BaseBranchModal #branch-custom-input.hidden {
    display: none;
}

#branch-modal-buttons {
    width: 100%;
    height: auto;
    align: center middle;
    padding-top: 1;
}

#branch-modal-buttons Button {
    margin: 0 1;
}

/* =============================================================================
   PAIR INSTRUCTIONS MODAL (tmux gateway)
   ============================================================================= */

PairInstructionsModal {
    align: center middle;
}

#pair-instructions-container {
    width: 70;
    height: auto;
    max-height: 32;
    border: round $primary;
    background: $surface;
    padding: 1 2;
}

PairInstructionsModal .modal-title {
    text-align: center;
    text-style: bold;
    width: 100%;
    color: $primary;
    padding-bottom: 1;
}

PairInstructionsModal .section-title {
    text-style: bold;
    color: $text-muted;
    width: 100%;
    text-align: center;
    padding: 1 0;
}

.tmux-intro {
    width: 100%;
    text-align: center;
    color: $text;
    padding: 1 0;
}

.hotkey-list {
    width: 100%;
    padding: 0 2;
}

.tmux-hotkey-row {
    width: 100%;
    height: 1;
    padding: 0 1;
}

.tmux-key {
    width: 16;
    min-width: 16;
    color: $primary;
    text-style: bold;
}

.tmux-desc {
    width: 1fr;
    color: $text;
}

.tmux-link {
    width: 100%;
    text-align: center;
    color: $secondary;
    padding: 1 0;
}

.tmux-link:hover {
    text-style: bold underline;
    tint: $primary 10%;
}

.tmux-hint {
    padding-top: 1;
}

/* DiffModal styles */
DiffModal {
    align: center middle;
}

#diff-container {
    width: 90%;
    height: 80%;
    background: $surface;
    border: round $primary;
    padding: 1 2;
}

#diff-log {
    height: 1fr;
    background: $background;
    border: round $border;
    padding: 0 1;
    scrollbar-gutter: stable;
}

/* StatusBar widget */
StatusBar {
    height: 1;
    background: $panel;
    layout: horizontal;
    padding: 0 1;
    border-top: solid $border;
}

.status-left {
    width: auto;
    color: $text;
}

.status-right {
    width: 1fr;
    text-align: right;
    color: $text-muted;
}

.keybinding-hint {
    dock: bottom;
    width: 100%;
    padding: 0 1;
    color: $text-muted;
    background: $surface;
    border-top: solid $border;
}

/* =============================================================================
   WELCOME SCREEN
   ============================================================================= */

/* Welcome Screen Styles */
WelcomeScreen {
    align: center middle;
    background: $background;
}

#welcome-container {
    width: 95%;
    max-width: 70;
    height: auto;
    max-height: 90%;
    padding: 1 2;
    border: round $primary;
    background: $surface;
    overflow-y: auto;
}

#logo {
    width: 100%;
    text-align: center;
    color: $primary;
    padding: 0 0 1 0;
}

#subtitle {
    text-align: center;
    margin-bottom: 1;
    color: $text;
    width: 100%;
}

.section-label {
    margin-top: 1;
    color: $text-muted;
}

#base-branch-select {
    width: 100%;
    margin: 0 0 1 0;
}

.info-label {
    color: $text-muted;
}

.settings-header {
    margin-top: 1;
}

.toggle-row {
    width: 100%;
    min-height: 1;
    height: auto;
    padding: 0;
    margin-bottom: 1;
    align: left middle;
}

.toggle-row .toggle-checkbox {
    width: auto;
}

#git-init-hint {
    text-align: center;
    margin: 1 0 0 0;
    width: 100%;
}

#buttons {
    margin-top: 2;
    margin-bottom: 2;
    width: 100%;
    align: center middle;
}

#buttons Button {
    min-width: 20;
}

/* Welcome screen footer positioning */
WelcomeScreen Footer {
    dock: bottom;
}

.hidden {
    display: none;
}

/* === Welcome Screen Project Picker === */
#recent-header {
    padding: 0 0 1 0;
    text-style: bold;
    color: $text-muted;
}

#project-list {
    height: 6;
    max-height: 6;
    min-height: 0;
    margin-bottom: 1;
    padding: 0;
}

#project-list > ListItem {
    background: $surface;
    border-left: solid $surface;
    padding: 0;
    height: auto;
}

#project-list > ListItem.-hovered,
#project-list > ListItem.-highlight {
    background: $panel;
    border-left: solid $primary;
}

#project-list:focus > ListItem.-highlight {
    background: $primary 18%;
    border-left: thick $primary;
}

#project-list > ListItem.-highlight .project-name,
#project-list > ListItem.-highlight .project-time {
    color: $text;
}

#project-list > ListItem.-highlight .project-repos,
#project-list > ListItem.-highlight .project-tasks {
    color: $text-muted;
    text-opacity: 100%;
}

#empty-state {
    text-align: center;
    color: $text-muted;
    padding: 2;
}

.project-item {
    padding: 0 1;
    height: 1;
}

.project-name {
    text-style: bold;
    color: $text;
    height: 1;
    width: 22;
}

.project-repos {
    color: $text-muted;
    height: 1;
    width: 1fr;
}

.project-tasks {
    color: $text-muted;
    height: 1;
    width: 20;
}

.project-time {
    width: 8;
    color: $text-muted;
    text-align: right;
}

#actions {
    padding: 0 0 1 0;
    height: auto;
    align: center middle;
}

#actions Button {
    margin: 0 1;
}

#admin-mcp-hint {
    width: 100%;
    text-align: center;
    color: $text-muted;
    padding: 0 1 1 1;
}

/* =============================================================================
   TASK OUTPUT SCREEN
   ============================================================================= */

TaskOutputScreen {
    background: $background;
}

#task-output-screen-root {
    width: 100%;
    height: 1fr;
    layout: vertical;
}

#task-output-top {
    width: 100%;
    height: 1fr;
    min-height: 10;
    padding: 1 2 0 2;
    background: $surface;
}

#task-output-title {
    width: 100%;
    text-style: bold;
    color: $primary;
}

#task-output-branch {
    width: 100%;
    color: $text-muted;
    overflow: hidden;
    text-overflow: ellipsis;
}

#task-output-status {
    width: 100%;
    color: $text-muted;
    padding-bottom: 1;
}

#task-output-diff-stats {
    width: 100%;
    color: $text;
    padding-top: 1;
    padding-bottom: 1;
}

#task-output-files {
    width: 100%;
    height: 1fr;
    min-height: 4;
    overflow-y: auto;
    color: $text-muted;
}

TaskOutputScreen.task-output-terminal-fullscreen #task-output-top {
    display: none;
    height: 0;
    min-height: 0;
}

/* =============================================================================
   REVIEW MODAL
   ============================================================================= */

ReviewModal {
    align: center middle;
}

#review-modal-container {
    width: 95%;
    height: 90%;
    layout: vertical;
    background: $surface;
    border: round $primary;
    padding: 1 2;
    overflow: hidden;
}

ReviewModal .modal-title {
    text-style: bold;
    color: $primary;
}

ReviewModal #review-title {
    width: 100%;
    text-align: left;
    padding-bottom: 0;
}

ReviewModal .branch-info {
    width: 100%;
    text-align: left;
    color: $text-muted;
    overflow: hidden;
    text-overflow: ellipsis;
    padding-bottom: 1;
}

ReviewModal .section-title {
    text-style: bold;
    color: $text-muted;
    padding-top: 1;
    padding-bottom: 0;
}

#review-meta-row {
    display: none;
}

#review-tabs {
    height: 1fr;
    min-height: 10;
}

#review-split {
    height: 1fr;
    layout: vertical;
}

#review-session-pane {
    height: 1fr;
    min-height: 10;
    border-top: solid $border;
    padding-top: 1;
}

ReviewModal #review-session-pane.overlay-only {
    border-top: none;
    padding-top: 0;
}

ReviewModal #review-session-pane.overlay-only #review-session-header {
    display: none;
}

ReviewModal #review-session-pane.overlay-only #session-state-note {
    display: none;
}

ReviewModal.review-terminal-fullscreen #review-tabs {
    display: none;
    height: 0;
    min-height: 0;
}

ReviewModal.review-terminal-fullscreen #review-session-pane {
    height: 1fr;
    min-height: 0;
    border-top: none;
    padding-top: 0;
}

ReviewModal.review-terminal-fullscreen #session-state-note {
    display: none;
}

ReviewModal.review-terminal-fullscreen ChatOverlay.embedded {
    border: none;
    margin: 0;
}

ReviewModal #review-session-pane ChatOverlay {
    layer: default;
    dock: none;
    width: 100%;
    height: 1fr;
    max-height: 1fr;
    min-height: 0;
    border: round $border;
    border-top: solid $border;
    padding: 0;
    margin: 0 0 1 0;
    offset-y: 0;
}

ReviewModal #review-session-pane ChatOverlay.hidden {
    display: none;
}

ReviewModal #review-session-pane ChatOverlay #chat-overlay-main {
    padding: 0 1;
    min-height: 0;
}

ReviewModal #review-session-pane ChatOverlay #chat-overlay-empty-state {
    display: none;
}

ReviewModal #review-session-pane ChatOverlay #chat-overlay-content {
    min-height: 0;
}

ReviewModal #review-session-pane ChatOverlay #chat-overlay-output {
    min-height: 0;
}

#review-session-header {
    width: 100%;
    height: auto;
    align: left middle;
}

#review-session-header .spacer {
    width: 1fr;
}

.session-badge {
    width: auto;
    color: $text-muted;
    margin-left: 1;
}

ReviewModal TabbedContent {
    height: 1fr;
}

ReviewModal TabbedContent > ContentSwitcher {
    height: 1fr;
}

ReviewModal TabPane {
    height: 1fr;
}

#review-summary-scroll {
    height: 1fr;
    padding-right: 1;
}

#review-task-summary {
    padding: 1 1;
    background: $background;
    border: round $primary;
    height: auto;
    margin-bottom: 1;
}

#review-stats {
    height: auto;
    margin: 0 0 1 0;
    align: left middle;
}

#review-stats .stat-card {
    height: 3;
    min-width: 18;
    padding: 0 1;
    text-align: center;
    background: $background;
    border: round $border;
    margin-right: 1;
}

#commits-table {
    height: auto;
    max-height: 8;
    background: $surface;
    border: none;
}

#diff-stats {
    padding: 0 1;
    background: $background;
    border: round $border;
    height: auto;
    min-height: 2;
    max-height: 6;
}

#review-description {
    padding: 0 1;
    background: $background;
    border: round $border;
    height: auto;
}

#task-output-status {
    color: $text-muted;
    padding: 0 1;
}

#diff-pane {
    height: 1fr;
    width: 100%;
}

#diff-files {
    width: 32;
    height: 1fr;
    background: $surface;
    border: round $border;
    margin-right: 1;
}

#diff-files.hidden {
    display: none;
}

#diff-log {
    height: 1fr;
    background: $background;
    border: none;
}

/* AI Review section - expandable, takes remaining space */
#ai-review-section {
    height: 1fr;
    min-height: 10;
    padding-top: 1;
}

#ai-review-header {
    width: 100%;
    height: auto;
    align: left middle;
    margin-bottom: 1;
}

#ai-review-header .spacer {
    width: 1fr;
}

.task-output-state-note {
    color: $text-muted;
    padding: 0 1;
    margin-bottom: 1;
}

.phase-badge {
    width: auto;
    padding: 0 1;
    text-style: bold;
    border: round $border;
    background: $panel;
    margin-left: 1;
}

.decision-badge {
    width: auto;
    padding: 0 1;
    text-style: bold;
    border: round $border;
    background: $panel;
}

.decision-pending {
    color: $text-muted;
}

.decision-approved {
    color: $success;
    border: round $success;
}

.decision-rejected {
    color: $error;
    border: round $error;
}

.phase-idle {
    color: $text-muted;
}

.phase-thinking {
    color: $warning;
}

.phase-streaming {
    color: $secondary;
}

.phase-complete {
    color: $success;
}

/* ChatPanel inside ReviewModal - must fill available space */
#ai-review-chat {
    height: 1fr;
    min-height: 6;
}

#ai-review-chat.hidden {
    display: none;
}

#review-agent-output-chat {
    height: 1fr;
    min-height: 6;
}

#review-agent-output-chat.hidden {
    display: none;
}

/* StreamingOutput inside review chat - explicit height */
#ai-review-output {
    height: 1fr;
    min-height: 6;
    background: $background;
    border: round $border;
}

ReviewModal .hint-label {
    padding-top: 1;
}

ReviewModal .button-row {
    dock: bottom;
    align: center middle;
    border-top: solid $border;
    padding: 1 0;
    height: auto;
    width: 100%;
    background: $surface;
}

ReviewModal #review-keyboard-hint {
    width: 100%;
    text-align: center;
    color: $text-disabled;
    text-opacity: 100%;
}

ReviewModal .button-row .button-group {
    height: auto;
    align: center middle;
    display: none;
}

ReviewModal .button-row .spacer {
    width: 1fr;
    display: none;
}

ReviewModal .button-row .button-group-start Button {
    margin-right: 1;
}

ReviewModal .button-row .button-group-end Button {
    margin-left: 1;
}

#ai-review-chat.queue-disabled .chat-input {
    display: none;
}

#review-agent-output-chat.queue-disabled .chat-input {
    display: none;
}

/* PR Comments tab */
#pr-comments-scroll {
    height: 1fr;
    padding-right: 1;
}

#pr-comments-loading {
    height: 3;
}

#pr-comments-loading.hidden {
    display: none;
}

.pr-comment-item {
    padding: 1;
    margin-bottom: 1;
    background: $background;
    border: round $border;
    height: auto;
}

.pr-comment-resolve-btn {
    dock: bottom;
    width: auto;
    min-width: 0;
    margin-top: 1;
    background: transparent;
    border: none;
    color: $text-disabled;
    text-opacity: 100%;
}

.pr-comment-resolve-btn:focus {
    color: $secondary;
    text-style: bold;
}

/* =============================================================================
   REJECTION INPUT MODAL
   ============================================================================= */

RejectionInputModal {
    align: center middle;
}

#rejection-input-container {
    width: 70;
    height: auto;
    background: $surface;
    border: round $error;
    padding: 2 3;
}

RejectionInputModal .modal-title {
    text-align: center;
    text-style: bold;
    width: 100%;
    padding-bottom: 1;
    color: $error;
}

RejectionInputModal .task-label {
    color: $text-muted;
}

RejectionInputModal .prompt-label {
    color: $text;
    padding-top: 1;
}

#feedback-input {
    height: 10;
    background: $background;
    border: solid $border;
}

#feedback-input:focus {
    border: solid $primary;
}

RejectionInputModal .hint-label {
    padding-top: 1;
}

RejectionInputModal .button-row {
    height: auto;
    align: center middle;
    padding-top: 1;
}

RejectionInputModal .button-row Button {
    margin: 0 1;
}

/* =============================================================================
   STREAMING OUTPUT WIDGET
   ============================================================================= */

/* StreamingOutput widget */
StreamingOutput {
    height: 1fr;
    width: 1fr;
}

StreamingOutput > ScrollableContainer {
    height: 1fr;
    padding: 0 1;
    scrollbar-gutter: stable;
}

StreamingOutput > ScrollableContainer > Markdown {
    padding: 0;
}

StreamingOutput > RichLog {
    height: auto;
    max-height: 8;
    border-top: solid $surface-lighten-2;
}

/* =============================================================================
   SEARCH BAR
   ============================================================================= */

/* SearchBar widget - hidden by default */
SearchBar {
    dock: top;
    width: 100%;
    height: 3;
    display: none;
    padding: 0 1;
    background: $panel;
}

SearchBar.visible {
    display: block;
}

SearchBar Input {
    width: 100%;
    border: round $primary;
    background: $background;
}

SearchBar Input:focus {
    border: round $secondary;
}

/* Review queue hint */
#review-queue-hint {
    dock: bottom;
    width: 100%;
    height: 1;
    background: $surface;
    color: $text-muted;
    text-align: center;
    layer: overlay;
    padding: 0 1;
    offset-y: 100%;
}

#review-queue-hint.visible {
    offset-y: 0;
}

/* =============================================================================
   GLOBAL AGENT PICKER MODAL
   ============================================================================= */

GlobalAgentPickerModal {
    align: center middle;
}

#agent-picker-container {
    width: 60;
    height: auto;
    max-height: 80%;
    background: $surface;
    border: round $primary;
    padding: 1 2;
}

#agent-picker-description {
    width: 100%;
    color: $text-muted;
    padding-bottom: 1;
}

#agent-picker-body {
    width: 100%;
    height: auto;
}

#agent-picker-options {
    width: 100%;
    height: auto;
    max-height: 10;
    border: solid $border;
    background: $background;
}

#agent-picker-options > .option-list--option-highlighted {
    background: $primary 30%;
    color: $text;
}

/* =============================================================================
   SESSION PICKER MODAL
   ============================================================================= */

SessionPickerModal {
    align: center middle;
}

#session-picker-container {
    width: 72;
    height: auto;
    max-height: 80%;
    background: $surface;
    border: round $primary;
    padding: 1 2;
}

#session-picker-container .modal-title {
    text-align: center;
    text-style: bold;
    width: 100%;
    color: $primary;
    padding-bottom: 1;
}

#session-picker-filter {
    width: 100%;
    margin-bottom: 0;
}

#session-picker-match-count {
    width: 100%;
    color: $text-muted;
    padding: 0 0 1 0;
}

#session-picker-grid {
    width: 100%;
    height: auto;
}

#session-picker-grid .session-picker-column {
    width: 1fr;
    height: auto;
    margin-right: 1;
}

#session-picker-grid .session-picker-column:last-child {
    margin-right: 0;
}

#session-picker-grid .session-picker-column-title {
    width: 100%;
    color: $text-muted;
    text-style: bold;
    margin-bottom: 1;
}

#session-picker-groups,
#session-picker-options {
    width: 1fr;
    height: auto;
    max-height: 14;
    background: $background;
    border: solid $border;
}

#session-picker-groups > .option-list--option,
#session-picker-options > .option-list--option {
    padding: 0 1;
}

#session-picker-groups > .option-list--option-highlighted,
#session-picker-options > .option-list--option-highlighted {
    background: $primary 30%;
    color: $text;
}

#session-picker-groups:focus > .option-list--option-highlighted,
#session-picker-options:focus > .option-list--option-highlighted {
    background: $primary;
    color: $background;
    text-style: bold;
}

#session-picker-footer-hint {
    width: 100%;
    color: $text-muted;
}

/* =============================================================================
   SETTINGS MODAL
   ============================================================================= */

SettingsModal {
    align: center middle;
}

/* TaskEditorScreen styles */
TaskEditorScreen {
    align: center middle;
}

#task-editor-container {
    width: 90%;
    max-width: 80;
    height: 85%;
    background: $surface;
    border: round $primary;
    padding: 1 2;
}

#task-tabs {
    height: 1fr;
    width: 100%;
}

#task-tabs > ContentSwitcher {
    height: 1fr;
    padding: 1;
}

#task-tabs Tabs {
    width: 100%;
    dock: top;
}

#task-tabs Tab {
    padding: 0 2;
}

#task-tabs Tab.-active {
    background: $primary;
    color: $text;
}

.task-form {
    width: 100%;
    height: 1fr;
    padding: 1;
    overflow-y: auto;
}

.task-input {
    width: 100%;
    margin-bottom: 1;
    background: $background;
    border: solid $border;
}

.task-input:focus {
    border: solid $primary;
}

.task-textarea {
    width: 100%;
    height: auto;
    min-height: 4;
    max-height: 10;
    margin-bottom: 1;
    background: $background;
    border: solid $border;
}

.task-textarea:focus {
    border: solid $primary;
}

.task-select {
    width: 100%;
    margin-bottom: 1;
}

.task-label {
    width: 100%;
    height: 1;
    color: $text;
    text-style: bold;
}

#finish-btn {
    dock: bottom;
    width: 100%;
    margin-top: 1;
}

/* =============================================================================
   STREAMING OUTPUT & AGENT CONTENT WIDGETS
   ============================================================================= */

/* ChatPanel widget */
ChatPanel {
    width: 100%;
    height: 1fr;
}

ChatPanel .chat-output {
    height: 1fr;
}

ChatPanel .chat-input {
    height: auto;
    padding: 1;
    border-top: solid $border;
    background: $panel;
    background-tint: 4%;
}

ChatPanel .chat-input-area {
    height: auto;
    min-height: 3;
    max-height: 8;
    border: round $border;
    background: $surface;
    background-tint: 4%;
    color: $text;
    padding: 0 1;
}

ChatPanel .chat-input-area:focus {
    border: round $primary;
    background: $surface;
    background-tint: 12%;
}

/* Queued messages container */
ChatPanel .queued-messages-container {
    width: 100%;
    height: auto;
    max-height: 8;
    margin-bottom: 1;
    border: round $border;
    background: $panel;
    background-tint: 6%;
    padding: 0 1;
}

ChatPanel .queued-messages-header {
    width: 100%;
    height: 1;
    color: $text-muted;
    text-style: italic;
    padding: 0;
}

ChatPanel .queued-message-row {
    width: 100%;
    height: auto;
    align: left middle;
    padding: 0;
}

ChatPanel .queued-message-text {
    width: 1fr;
    height: auto;
    color: $text;
    padding: 0;
}

ChatPanel .queued-message-remove {
    width: 3;
    min-width: 3;
    height: 1;
    background: transparent;
    color: $error;
    border: none;
    padding: 0;
    margin: 0;
}

ChatPanel .queued-message-remove:hover {
    background: $error;
    color: $background;
}

ChatPanel .queued-message-remove:focus {
    background: $error;
    color: $background;
    text-style: bold;
}

/* StreamingOutput container (VerticalScroll) */
StreamingOutput {
    width: 100%;
    height: 1fr;
    min-height: 5;
    padding: 1 2;
    scrollbar-gutter: stable;
}

/* UserInput widget — left-accent strip, no full box */
.user-input {
    width: 100%;
    height: auto;
    margin-bottom: 1;
    padding: 0 1 0 2;
    border-left: thick $primary;
    background: $panel;
    color: $text;
}

.user-input-prompt {
    width: auto;
    min-width: 3;
    color: $primary;
    text-style: bold;
    margin-right: 1;
}

.user-input-content {
    width: 1fr;
    height: auto;
    color: $text;
}

.user-input-content > * {
    margin: 0;
}

/* AgentResponse widget — borderless, content is the UI */
.agent-response {
    width: 100%;
    height: auto;
    min-height: 1;
    margin-bottom: 1;
    padding: 0 1 0 2;
    border-left: thick $border;
}

.agent-response > * {
    margin: 0;
}

/* AgentThought widget — muted left-accent strip */
.agent-thought {
    width: 100%;
    height: auto;
    min-height: 1;
    margin-bottom: 1;
    padding: 0 1 0 2;
    color: $text-muted;
    border-left: thick $border;
}

.agent-thought > * {
    margin: 0;
}

/* Copyable content hover states */
.agent-response:hover,
.agent-thought:hover,
.user-input:hover {
    tint: $primary 8%;
}

.user-input:focus {
    tint: $primary 12%;
    border-left: thick $primary;
    background: $panel;
}

ToolCall:hover {
    tint: $primary 10%;
}

.plan-entry:hover {
    tint: $primary 10%;
}

.plan-entry:focus {
    tint: $primary 15%;
    background: $surface;
}

/* ToolCall widget (expandable tool call display) */
.tool-call {
    width: 100%;
    height: auto;
    margin-bottom: 1;
}

.tool-call:focus {
    tint: $primary 15%;
    background: $surface;
}

#tool-content {
    display: none;
}

ToolCall.-expanded #tool-content {
    display: block;
}

ToolCallHeader {
    width: 100%;
    height: auto;
    padding: 0 1;
}

ToolCallHeader:hover {
    background: $surface;
}

ToolCall:focus ToolCallHeader {
    background: $panel;
    text-style: bold;
}

TextContent {
    width: 100%;
    height: auto;
    padding: 0 2;
    color: $text-muted;
}

MarkdownContent {
    width: 100%;
    height: auto;
    padding: 0 2;
    margin: 0;
}

.tool-content-label {
    width: 100%;
    height: auto;
    padding: 0 2;
    margin-top: 1;
    color: $text-muted;
    text-style: bold;
}

.tool-diff {
    color: $text;
}

/* Stream status — inline in scroll flow, not docked */
#stream-current-action {
    width: 100%;
    height: auto;
    margin-bottom: 1;
    padding: 0 1;
    color: $text-disabled;
}

#stream-current-action.confidence-certain {
    color: $text-muted;
}

#stream-current-action.confidence-assumption {
    color: $warning;
}

#stream-current-action.confidence-needs-validation {
    color: $error;
}

#stream-live-jump-row {
    dock: bottom;
    width: 100%;
    height: auto;
    align: center middle;
    padding: 0 1 1 1;
    background: transparent;
    display: none;
}

#stream-jump-live-btn {
    width: auto;
    border: round $primary;
    background: $primary 15%;
    color: $text;
    text-style: bold;
}

#stream-jump-live-btn:hover,
#stream-jump-live-btn:focus {
    background: $primary;
    color: $background;
}

/* Streaming notes with status classes */
.streaming-note {
    width: 100%;
    height: auto;
    padding: 0 1;
    margin-bottom: 1;
}

.streaming-note.success {
    color: $success;
}

.streaming-note.error {
    color: $error;
}

.streaming-note.warning {
    color: $warning;
}

.streaming-note.session-snapshot {
    color: $text-muted;
}

.streaming-note.info {
    color: $text-muted;
}

.streaming-note.dismissed {
    color: $text-muted;
    text-style: italic;
}

/* Thinking indicator */
.thinking-indicator {
    width: 100%;
    height: auto;
    padding: 0 1;
    margin-bottom: 1;
    color: $text-muted;
    text-style: italic;
}

/* Turn separator */
.turn-separator {
    width: 100%;
    height: 1;
    margin: 1 0;
    background: $border;
    color: $text-disabled;
}

/* Enhanced plan display */
.plan-display {
    width: 100%;
    height: auto;
    margin: 1 0;
    padding: 1;
    border: round $border;
    background: $surface;
}

.plan-display .plan-title {
    color: $text-muted;
    text-style: bold;
    margin-bottom: 1;
}

/* Streaming indicator (awaiting response) */
.streaming-indicator {
    width: 100%;
    height: auto;
    padding: 0 1;
    color: $text-muted;
}

/* =============================================================================
   PERMISSION PROMPT WIDGET
   ============================================================================= */

/* Permission Prompt Widget */
.permission-prompt {
    background: $surface;
    border: round $warning;
    padding: 1 2;
    margin: 1 0;
}

.permission-prompt:focus {
    background: $panel;
    border: round $primary;
}

.permission-prompt .permission-header {
    text-style: bold;
    color: $warning;
}

.permission-prompt .permission-tool {
    margin-top: 1;
    color: $text-muted;
}

.permission-prompt .permission-controls {
    margin-top: 1;
    text-align: center;
    color: $text-muted;
    text-style: dim;
}

.permission-prompt .permission-timer {
    margin-top: 1;
    color: $text-muted;
    text-style: italic;
}

/* =============================================================================
   HELP MODAL
   ============================================================================= */

HelpModal {
    align: center middle;
}

#help-container {
    width: 90%;
    max-width: 100;
    height: 85%;
    background: $surface;
    border: round $primary;
    padding: 1 2;
}

HelpModal .modal-title {
    text-align: center;
    text-style: bold;
    width: 100%;
    padding-bottom: 1;
    color: $primary;
}

#help-tabs {
    height: 1fr;
}

#help-tabs > ContentSwitcher {
    height: 1fr;
    padding: 0;
}

#help-tabs TabPane {
    padding: 0;
}

#help-tabs TabPane > VerticalScroll {
    height: 1fr;
    padding: 0 1;
    scrollbar-gutter: stable;
}

.help-section-title {
    text-style: bold underline;
    color: $primary;
    padding-top: 1;
    padding-bottom: 1;
}

.help-subsection {
    text-style: bold;
    color: $text;
    padding-top: 1;
}

.help-paragraph {
    color: $text;
    padding: 0 1;
}

.help-paragraph-indented {
    color: $text;
    padding: 0 2;
}

.help-code {
    color: $text-muted;
}

.help-key-row {
    width: 100%;
    height: 1;
    padding: 0 1;
}

.help-key {
    width: 19;
    min-width: 19;
    color: $primary;
    text-style: bold;
    padding-right: 1;
}

.help-desc {
    width: 1fr;
    color: $text;
    padding-left: 1;
}

/* =============================================================================
   SLASH COMPLETE WIDGET (Autocomplete Overlay)
   ============================================================================= */

/* Slash command autocomplete popup - overlays chat footer region. */
.slash-complete {
    layer: overlay;
    dock: bottom;
    /* Keep popup above the input row while still overlaying footer chrome. */
    offset-y: -5;
    width: 100%;
    height: auto;
    background: $surface;
    border: round $primary;
    margin: 0;
    padding: 0;
}

.slash-complete #slash-options {
    width: 100%;
    height: auto;
    max-height: 6;
    background: $surface;
    scrollbar-gutter: stable;
}

/* =============================================================================
   TASK MENTION AUTOCOMPLETE DROPDOWN
   ============================================================================= */

/* Task mention autocomplete dropdown overlay - full width, above status bar */
.task-mention-complete {
    dock: bottom;
    width: 100%;
    height: auto;
    max-height: 8;
    display: none;
    background: $surface;
    border-top: solid $primary;
    padding: 0;
    margin: 0;
}

.task-mention-complete.visible {
    display: block;
}

.task-mention-complete #mention-options {
    width: 100%;
    height: auto;
    max-height: 7;
    background: $surface;
    scrollbar-gutter: stable;
}

.slash-complete #slash-options > .option-list--option,
.task-mention-complete #mention-options > .option-list--option {
    padding: 0 1;
    color: $text;
    text-wrap: nowrap;
}

.slash-complete #slash-options > .option-list--option-highlighted,
.task-mention-complete #mention-options > .option-list--option-highlighted {
    background: $primary;
    color: $background;
    text-style: bold;
}

.slash-complete #slash-options > .option-list--option-hover,
.task-mention-complete #mention-options > .option-list--option-hover {
    background: $panel;
}

.slash-complete #slash-options > .option-list--option-disabled,
.task-mention-complete #mention-options > .option-list--option-disabled {
    color: $text-disabled;
    text-opacity: 100%;
}

/* =============================================================================
   PLAN APPROVAL WIDGET (Inline Plan Review)
   ============================================================================= */

/* Plan approval inline widget - similar pattern to permission-prompt */
.plan-approval {
    background: $panel;
    border: round $primary;
    padding: 1 2;
    margin: 1 0;
    width: 100%;
    height: auto;
}

.plan-approval:focus {
    border: round $primary-lighten-1;
    background: $surface;
}

.plan-approval .plan-header {
    text-style: bold;
    color: $primary;
    padding-bottom: 0;
}

.plan-approval .plan-hint {
    color: $text-muted;
    text-style: italic;
    padding-bottom: 1;
}

.plan-approval #task-list {
    width: 100%;
    height: auto;
    max-height: 15;
    padding: 0;
    margin-bottom: 1;
}

.plan-approval .task-row {
    width: 100%;
    height: auto;
    padding: 0 1;
    margin-bottom: 0;
    border-left: solid $border;
}

.plan-approval .task-row:hover {
    background: $surface;
}

.plan-approval .task-row.selected {
    background: $primary 20%;
    border-left: thick $primary;
    color: $text;
}

/* Priority accent colors for task rows */
.plan-approval .task-row.priority-critical {
    border-left: solid $error;
    color: $error;
}

.plan-approval .task-row.priority-high {
    border-left: solid $warning;
}

.plan-approval .task-row.priority-medium {
    border-left: solid #b8a965;
}

.plan-approval .task-row.priority-low {
    border-left: solid $success;
}

.plan-approval .task-title-text {
    color: $text;
}

.plan-approval .task-priority-badge {
    color: $text-muted;
    padding-left: 1;
}

.plan-approval #approval-buttons {
    width: 100%;
    height: auto;
    layout: horizontal;
    align: center middle;
    padding-top: 1;
}

.plan-approval #approval-buttons Button {
    margin: 0 1;
}

.plan-approval #approval-buttons Button:focus {
    background: $primary;
    color: $background;
}

.plan-approval .approval-hint {
    width: 100%;
    text-align: center;
    color: $text-muted;
    padding-top: 1;
}

/* =============================================================================
   DEBUG LOG MODAL
   ============================================================================= */

DebugLogModal {
    align: center middle;
}

#debug-log-container {
    width: 90%;
    height: 90%;
    background: $surface;
    border: round $primary;
    padding: 1;
}

#debug-log {
    height: 1fr;
    background: $surface-darken-1;
    border: round $primary-lighten-2;
    padding: 0 1;
}

/* =============================================================================
   KEYBINDING HINT WIDGET (single-line — Welcome, RepoPicker, etc.)
   ============================================================================= */

KeybindingHint {
    dock: bottom;
    height: 1;
    background: $surface;
    color: $text-muted;
    text-align: center;
    padding: 0 1;
}

KeybindingHint:empty {
    display: none;
}

/* =============================================================================
   KANBAN HINT BAR (two-row — Kanban board)
   ============================================================================= */

KanbanHintBar {
    dock: bottom;
    height: 2;
    background: $surface;
    color: $text-muted;
    border-top: solid $border;
}

KanbanHintBar .hint-bar-row {
    height: 1;
    width: 100%;
}

/* Row 1: Navigation — movement arrows */
KanbanHintBar .hint-bar-nav {
    background: $surface;
}

KanbanHintBar .hint-nav-left {
    width: 1fr;
    text-align: left;
    padding: 0 1;
    color: $text-muted;
}

KanbanHintBar .hint-nav-center {
    width: auto;
    text-align: center;
    padding: 0 2;
    color: $text-disabled;
}

KanbanHintBar .hint-nav-right {
    width: 1fr;
    text-align: right;
    padding: 0 1;
    color: $text-muted;
}

/* Row 2: Actions — context-sensitive + global */
KanbanHintBar .hint-bar-actions {
    background: $surface;
}

KanbanHintBar .hint-actions-left {
    width: 1fr;
    text-align: left;
}

KanbanHintBar .hint-actions {
    width: auto;
    text-align: center;
    padding: 0 2;
    color: $text-muted;
}

KanbanHintBar .hint-global {
    width: 1fr;
    text-align: right;
    padding: 0 1;
    color: $text-disabled;
}

/* When orchestrator overlay is visible, hide board chrome under it. */
KanbanScreen.chat-overlay-visible KanbanHintBar {
    display: none;
}

KanbanScreen.chat-overlay-visible #review-queue-hint {
    display: none;
}

/* =============================================================================
   NEW PROJECT MODAL
   ============================================================================= */

NewProjectModal {
    align: center middle;
}

NewProjectModal #dialog {
    width: 60;
    height: auto;
    border: round $primary;
    background: $surface;
    padding: 2 3;
}

NewProjectModal .dialog-title {
    text-align: center;
    text-style: bold;
    color: $primary;
    padding-bottom: 1;
}

NewProjectModal .field {
    height: auto;
    margin: 1 0 0 0;
}

NewProjectModal .field-label {
    margin-bottom: 0;
    color: $text;
    text-style: bold;
}

NewProjectModal .hint {
    color: $text-muted;
    text-style: italic;
}

NewProjectModal #dialog-actions {
    height: auto;
    margin-top: 2;
    align: center middle;
}

NewProjectModal #dialog-actions Button {
    margin: 0 1;
    min-width: 16;
}

/* =============================================================================
   FOLDER PICKER MODAL
   ============================================================================= */

FolderPickerModal {
    align: center middle;
}

FolderPickerModal #dialog {
    width: 60;
    height: auto;
    border: round $primary;
    background: $surface;
    padding: 2 3;
}

FolderPickerModal .dialog-title {
    text-align: center;
    text-style: bold;
    color: $primary;
    padding-bottom: 1;
}

FolderPickerModal .field {
    height: auto;
    margin: 1 0 0 0;
}

FolderPickerModal .field-label {
    margin-bottom: 0;
    color: $text;
    text-style: bold;
}

FolderPickerModal .hint {
    color: $text-muted;
    text-style: italic;
}

FolderPickerModal #dialog-actions {
    height: auto;
    margin-top: 2;
    align: center middle;
}

FolderPickerModal #folder-tree {
    height: 12;
    max-height: 14;
    border: round $border;
    background: $background;
    padding: 0 1;
}

FolderPickerModal #dialog-actions Button {
    margin: 0 1;
    min-width: 16;
}

/* === Start Workspace Modal === */
StartWorkspaceModal {
    align: center middle;
}

StartWorkspaceModal #dialog {
    width: 70;
    height: auto;
    max-height: 80%;
    border: round $primary;
    padding: 2 3;
}

StartWorkspaceModal .dialog-title {
    text-style: bold;
    padding-bottom: 1;
}

StartWorkspaceModal .task-name {
    color: $text;
    padding-bottom: 1;
}

StartWorkspaceModal .section-header {
    text-style: bold;
    padding: 1 0 0 0;
}

StartWorkspaceModal .section-hint {
    color: $text-muted;
    padding-bottom: 1;
}

StartWorkspaceModal #repo-list {
    height: auto;
    max-height: 20;
    border: solid $surface;
    padding: 1;
}

StartWorkspaceModal .repo-row {
    height: auto;
    min-height: 1;
    align: left middle;
}

StartWorkspaceModal .repo-row Checkbox {
    margin-right: 1;
}

StartWorkspaceModal .repo-path {
    color: $text-muted;
    padding-left: 2;
}

StartWorkspaceModal .repo-branch {
    dock: right;
    color: $text-muted;
}

StartWorkspaceModal #executor-section {
    padding-top: 1;
}

StartWorkspaceModal #actions {
    height: auto;
    margin-top: 2;
    align: center middle;
}

StartWorkspaceModal #actions Button {
    margin: 0 1;
    min-width: 16;
}

StartWorkspaceModal .error {
    color: $error;
    padding-top: 1;
}

/* === Workspace Repos Widget === */
WorkspaceReposWidget {
    height: auto;
    border: solid $primary;
    padding: 1;
}

WorkspaceReposWidget:focus {
    background: $panel;
}

WorkspaceReposWidget .workspace-repos-hint {
    color: $text-muted;
    text-style: italic;
    padding: 0 0 1 0;
}

WorkspaceReposWidget .repo-item {
    height: 3;
    padding: 0 1;
    border-left: solid $surface;
}

WorkspaceRepoItem.selected .repo-item {
    background: $primary 15%;
    border-left: thick $primary;
}

WorkspaceRepoItem:focus-within .repo-item {
    background: $panel;
    border-left: solid $secondary;
}

WorkspaceReposWidget .repo-name {
    width: 20;
}

WorkspaceReposWidget .has-changes {
    color: $warning;
}

WorkspaceReposWidget .no-changes {
    color: $text-muted;
}

WorkspaceReposWidget .target-branch {
    width: 15;
    color: $text-muted;
}

WorkspaceReposWidget .diff-stats {
    width: 12;
}

WorkspaceReposWidget .btn-diff, WorkspaceReposWidget .btn-merge {
    margin-left: 1;
}

WorkspaceReposWidget .btn-diff:focus,
WorkspaceReposWidget .btn-merge:focus {
    background: $primary;
    color: $background;
}

/* === Merge Dialog === */
MergeDialog {
    align: center middle;
}

#merge-container {
    width: 70;
    height: auto;
    max-height: 80%;
    background: $surface;
    border: round $primary;
    padding: 2 3;
}

MergeDialog .merge-row {
    height: auto;
    min-height: 1;
    align: left middle;
    padding: 0 1;
}

MergeDialog .merge-row Checkbox {
    margin-right: 1;
}

MergeDialog .target-branch {
    color: $text-muted;
    margin-left: 2;
}

MergeDialog .diff-stats {
    dock: right;
}

#strategy-select {
    margin: 1 0;
}

#button-row {
    height: auto;
    margin-top: 1;
    align: center middle;
}

/* === Diff Modal === */
DiffModal {
    align: center middle;
}

#diff-container {
    width: 90%;
    height: 90%;
    background: $surface;
    border: round $primary;
}

DiffModal .diff-content {
    background: $background;
    padding: 1;
}

DiffModal .diff-header {
    background: $primary-darken-2;
    padding: 0 1;
}

/* =============================================================================
   ONBOARDING SCREEN
   ============================================================================= */

OnboardingScreen {
    align: center middle;
    background: $background;
}

#onboarding-container {
    width: 70;
    height: auto;
    max-height: 90%;
    background: $surface;
    border: round $primary;
    padding: 2 3;
    overflow-y: auto;
}

/* --- Logo zone --- */
#onboarding-logo {
    width: 100%;
    text-align: center;
    color: $primary;
    padding: 0;
}

#onboarding-subtitle {
    text-align: center;
    color: $text-muted;
    text-style: italic;
    width: 100%;
    margin-bottom: 1;
}

#onboarding-divider {
    color: $border;
    margin: 0 2 1 2;
}

/* --- Form zone --- */
#onboarding-form {
    width: 100%;
    height: auto;
    padding: 0 1;
}

#onboarding-form .form-label {
    color: $text;
    text-style: bold;
    margin-top: 1;
    margin-bottom: 0;
}

#onboarding-form .form-hint {
    color: $text-muted;
}

#onboarding-form Select {
    width: 100%;
    margin-bottom: 1;
}

/* --- Toggle row --- */
#auto-review-row {
    width: 100%;
    height: auto;
    margin-top: 1;
    padding: 1 1;
    background: $surface;
    border: round $border;
    align: left middle;
}

#auto-review-info {
    width: 1fr;
    height: auto;
}

#auto-review-row .onboarding-auto-review-checkbox {
    margin-top: 0;
    margin-bottom: 0;
}

/* --- CTA zone --- */
#onboarding-actions {
    width: 100%;
    height: auto;
    align: center middle;
    margin-top: 2;
}

#onboarding-actions Button {
    margin: 0 1;
    min-width: 24;
}

#onboarding-keyboard-hint {
    width: 100%;
    text-align: center;
    color: $text-muted;
    margin-top: 1;
}

/* =============================================================================
   CWD SUGGESTION BANNER (Inside Welcome Container)
   ============================================================================= */

#cwd-suggestion-banner {
    width: 100%;
    height: auto;
    background: $primary 10%;
    border: solid $primary;
    padding: 1 2;
    margin: 1 0;
}

#cwd-title {
    text-style: bold;
    color: $primary;
}

#cwd-path {
    color: $text-muted;
    margin-left: 2;
    margin-bottom: 1;
}

#cwd-actions {
    height: auto;
    margin-left: 2;
}

#cwd-actions Button {
    margin-right: 1;
}

/* =============================================================================
   OFFLINE BANNER
   ============================================================================= */

OfflineBanner {
    dock: top;
    width: 100%;
    height: auto;
    background: $warning 20%;
    border-bottom: solid $warning;
    padding: 1 2;
}

OfflineBanner:focus {
    background: $warning 30%;
    border-bottom: solid $primary;
}

#offline-title {
    text-style: bold;
    color: $warning;
}

#offline-message {
    color: $text-muted;
    margin-left: 2;
}

#offline-actions {
    margin-top: 1;
    height: auto;
}

#offline-actions Button {
    margin-right: 1;
}

#offline-actions Button:focus {
    background: $primary;
    color: $background;
}

/* =============================================================================
   CONTINUE HIGHLIGHT (Welcome Screen)
   ============================================================================= */

#continue-highlight {
    display: none;
    width: 100%;
    height: auto;
    background: $primary 10%;
    border: solid $primary;
    padding: 0 1;
    margin-bottom: 1;
}

#continue-title {
    text-style: bold;
    color: $primary;
}

#continue-project-name {
    text-style: bold;
    color: $text;
    margin-left: 1;
}

#continue-project-info {
    color: $text-muted;
    margin-left: 1;
}

#continue-hint {
    color: $text-muted;
    margin-top: 0;
}

/* Project shortcut number indicator */
.project-shortcut {
    width: 4;
    color: $primary;
    text-style: bold;
}

/* =============================================================================
   REPO PICKER SCREEN
   ============================================================================= */

RepoPickerScreen {
    align: center middle;
    background: $background;
}

#repo-picker-container {
    width: 70;
    height: auto;
    max-height: 70%;
    background: $surface;
    border: solid $primary;
    padding: 1 2;
}

#repo-picker-logo {
    width: 100%;
    text-align: center;
    color: $primary;
    text-style: bold;
}

#repo-picker-subtitle {
    width: 100%;
    text-align: center;
    color: $text-muted;
    margin-bottom: 1;
}

#repo-picker-project-name {
    width: 100%;
    text-align: center;
    color: $text;
    margin-bottom: 1;
}

#repo-picker-empty {
    width: 100%;
    text-align: center;
    color: $text-muted;
    margin: 1 0;
}

#repo-list {
    height: 8;
    max-height: 8;
    background: $surface;
    border: solid $surface-lighten-2;
    padding: 0;
}

#repo-picker-actions {
    width: 100%;
    padding-top: 0;
    align: center middle;
    margin-top: 0;
}

#repo-picker-actions Button {
    margin-right: 2;
}

.repo-item {
    padding: 0 1;
    height: 1;
}

#repo-list > ListItem {
    background: $surface;
    padding: 0;
    height: 1;
}

#repo-list > ListItem.-hovered,
#repo-list > ListItem.-highlight {
    background: $surface-lighten-2;
}

#repo-list:focus > ListItem.-highlight {
    background: $primary 15%;
}

.repo-indicator {
    width: 3;
    color: $primary;
    text-style: bold;
}

.repo-info {
    width: 1fr;
    height: 1;
}

.repo-name {
    color: $primary;
    text-style: bold;
    height: 1;
}

.repo-path {
    color: $text-muted;
    height: 1;
    width: 1fr;
}

.repo-tasks {
    width: auto;
    color: $text-muted;
    text-align: right;
}

/* ===========================================================================
   AGENT CHOICE MODAL
   =========================================================================== */

AgentChoiceModal {
    align: center middle;
}

#agent-choice-container {
    width: 65;
    height: auto;
    max-height: 80%;
    border: round $primary;
    background: $surface;
    padding: 2 3;
}

#agent-choice-title {
    text-style: bold;
    text-align: center;
    width: 100%;
    color: $warning;
    padding-bottom: 1;
}

#agent-choice-description {
    text-align: center;
    width: 100%;
    padding-bottom: 1;
}

#agent-choice-options {
    width: 100%;
    height: auto;
    align: center middle;
}

#fallback-label {
    text-align: center;
    width: 100%;
    padding: 1 0;
    color: $text-muted;
}

#agent-list {
    width: 100%;
    height: auto;
    max-height: 10;
    margin-bottom: 1;
}

#agent-choice-options Button {
    margin: 0 1;
}

#agent-choice-status {
    text-align: center;
    width: 100%;
    min-height: 1;
    color: $text-muted;
}
/* =============================================================================
   PEEK OVERLAY
   ============================================================================= */

PeekOverlay {
    layer: overlay;
    width: 50;
    height: auto;
    max-height: 12;
    background: $surface;
    border: round $primary;
    padding: 1;
    display: none;
    position: absolute;
    overflow-y: auto;
}

PeekOverlay.visible {
    display: block;
}

PeekOverlay .peek-title {
    text-style: bold;
    color: $primary;
    margin-bottom: 1;
}

PeekOverlay .peek-status {
    color: $text;
}

PeekOverlay .peek-content {
    color: $text-muted;
}

/* =============================================================================
   CHAT OVERLAY (bottom dock, expand from bottom)
   ============================================================================= */

ChatOverlay {
    layer: overlay;
    dock: bottom;
    width: 100%;
    height: 24;
    max-height: 50%;
    background: $surface;
    border-top: solid $primary;
    padding: 0;
    display: none;
    offset-y: 100%;
}

ChatOverlay.visible {
    display: block;
    offset-y: 0;
}

/* Fullscreen overlay state when fullscreen mode is active. */
ChatOverlay.visible.fullscreen {
    height: 1fr;
    max-height: 1fr;
    border-top: none;
    border: none;
    padding: 0;
    background: $background;
    overflow: hidden;
}

ChatOverlay.visible.docked {
    height: 50%;
    max-height: 50%;
    min-height: 3;
    overflow: hidden;
}

ChatOverlay #chat-overlay-logo {
    width: 100%;
    color: $primary;
    text-align: center;
    content-align: center middle;
    padding-bottom: 0;
}

ChatOverlay.visible.fullscreen #chat-overlay-logo {
    padding-bottom: 1;
}

ChatOverlay #chat-overlay-main {
    width: 100%;
    height: 1fr;
    min-height: 8;
    background: $background;
    layout: vertical;
    layers: default overlay;
    padding: 0;
}

ChatOverlay.visible.fullscreen #chat-overlay-main {
    padding: 0;
}

ChatOverlay.docked #chat-overlay-main {
    height: 1fr;
    min-height: 0;
}

ChatOverlay #chat-overlay-content {
    width: 100%;
    height: 1fr;
    layout: vertical;
    min-height: 0;
    padding: 1 1 0 1;
}

ChatOverlay.docked #chat-overlay-content {
    display: block;
    height: 1fr;
    min-height: 0;
    padding: 1 1 0 1;
}

ChatOverlay #chat-overlay-empty-state {
    width: 100%;
    height: 1fr;
    align: center middle;
    content-align: center middle;
    padding: 2 1 1 1;
}

ChatOverlay .chat-overlay-empty-content {
    width: auto;
    min-width: 46;
    max-width: 82;
    height: auto;
    align: center middle;
    content-align: center middle;
}

ChatOverlay .chat-overlay-empty-card {
    width: 100%;
    height: auto;
    background: transparent;
    border: none;
    align: center middle;
    padding: 2 2 1 2;
}

ChatOverlay #chat-overlay-empty-heading {
    width: 100%;
    text-style: bold;
    color: $primary;
    text-align: center;
    content-align: center middle;
    padding-bottom: 1;
}

ChatOverlay #chat-overlay-empty-quote {
    display: none;
    width: 100%;
    text-style: italic;
    text-align: center;
    color: $primary;
    text-opacity: 100%;
    padding-bottom: 1;
}

ChatOverlay.chat-overlay-has-quote #chat-overlay-empty-quote {
    display: block;
}

ChatOverlay #chat-overlay-empty-description {
    display: none;
    width: 100%;
    text-align: center;
    color: $text-muted;
    padding-bottom: 2;
}

ChatOverlay #chat-overlay-empty-examples {
    display: none;
    width: 100%;
    height: auto;
    align: center middle;
    margin-top: 1;
}

ChatOverlay .chat-overlay-empty-section-title {
    width: 100%;
    text-style: bold;
    text-align: center;
    color: $text-disabled;
    padding-top: 0;
}

ChatOverlay .chat-overlay-empty-example {
    width: 100%;
    text-align: center;
    color: $text-muted;
}

ChatOverlay.visible.fullscreen .chat-overlay-empty-content {
    min-width: 52;
    max-width: 82;
}

ChatOverlay.visible.fullscreen #chat-overlay-empty-description {
    display: block;
}

ChatOverlay.visible.fullscreen #chat-overlay-empty-examples {
    display: block;
}

ChatOverlay #chat-overlay-output {
    width: 100%;
    height: 1fr;
    min-height: 0;
    background: $background;
    display: none;
}

ChatOverlay #chat-overlay-output > ScrollableContainer {
    height: 1fr;
    padding: 1 2;
    scrollbar-gutter: stable;
}

ChatOverlay #chat-overlay-bottom {
    dock: bottom;
    height: auto;
    min-height: 5;
    width: 100%;
    padding: 0 1;
    margin: 0;
    background: $surface;
    border-top: solid $border;
}

ChatOverlay #chat-overlay-bottom:focus-within {
    border-top: solid $primary;
}

ChatOverlay.docked #chat-overlay-bottom {
    min-height: 4;
    max-height: 8;
    padding: 0 1;
}

ChatOverlay #chat-overlay-command-line {
    width: 100%;
    height: auto;
    min-height: 3;
    max-height: 6;
    align: left middle;
    padding: 0 1;
    margin: 0;
    background: $background;
    border: round $border;
}

ChatOverlay #chat-overlay-command-line:focus-within {
    background: $surface;
    border: round $primary;
    tint: $primary 4%;
}

ChatOverlay #chat-overlay-session-switcher {
    width: 100%;
    height: 1;
    min-height: 1;
    align: left middle;
    margin: 0;
    padding: 0 2;
}

ChatOverlay #chat-overlay-session-current-wrap {
    width: 1fr;
    height: 1;
    align: left middle;
}

ChatOverlay #chat-overlay-mode-badge {
    width: auto;
    margin-right: 1;
    padding: 0 1;
    border: none;
    background: transparent;
    color: $text-muted;
}

ChatOverlay #chat-overlay-mode-badge.mode-docked {
    color: $warning;
}

ChatOverlay #chat-overlay-mode-badge.mode-fullscreen {
    color: $primary;
}

ChatOverlay #chat-overlay-session-indicator {
    display: none;
}

ChatOverlay #chat-overlay-session-indicator.session-kind-orchestrator {
    color: $primary;
}

ChatOverlay #chat-overlay-session-indicator.session-kind-auto {
    color: $success;
}

ChatOverlay #chat-overlay-session-indicator.session-kind-review {
    color: $warning;
}

ChatOverlay #chat-overlay-session-indicator.session-kind-pair {
    color: $text;
}

ChatOverlay #chat-overlay-session-current {
    width: auto;
    color: $text-muted;
    text-opacity: 100%;
}

ChatOverlay.chat-overlay-multi-session #chat-overlay-session-current {
    color: $text-muted;
    text-opacity: 100%;
}

ChatOverlay #chat-overlay-session-toggle {
    display: none;
}

ChatOverlay #chat-overlay-session-toggle-label {
    display: none;
}

ChatOverlay #chat-overlay-session-select {
    display: none;
    width: auto;
    min-width: 10;
    max-width: 20;
    margin-left: 1;
    border: round $border;
    background: $background;
    color: $text;
    text-opacity: 100%;
}

ChatOverlay #chat-overlay-session-select:focus {
    border: round $primary;
    background: $surface;
}

ChatOverlay #chat-overlay-input-prompt {
    width: auto;
    color: $text;
    text-style: bold;
    padding-right: 1;
}

ChatOverlay #chat-overlay-status {
    height: 1;
    min-height: 1;
    margin: 0;
    border: none;
    background: transparent;
    padding: 0 1;
}

ChatOverlay.docked #chat-overlay-session-switcher {
    display: none;
}

ChatOverlay.docked #chat-overlay-command-line {
    margin: 0;
    min-height: 3;
    max-height: 6;
}

ChatOverlay.docked #chat-overlay-session-current,
ChatOverlay.docked #chat-overlay-session-indicator,
ChatOverlay.docked #chat-overlay-session-toggle,
ChatOverlay.docked #chat-overlay-session-select {
    display: none;
}

ChatOverlay #chat-overlay-status .status-left {
    color: $text-muted;
}

ChatOverlay #chat-overlay-status .status-right {
    color: $text-muted;
    text-opacity: 100%;
}

ChatOverlay #chat-overlay-input {
    width: 1fr;
    padding: 0;
    margin: 0;
    height: auto;
    min-height: 1;
    max-height: 6;
    border: none;
    background: transparent;
    color: $text;
}

ChatOverlay #chat-overlay-input:focus {
    border: none;
    background: transparent;
    color: $text;
}

ChatOverlay #chat-overlay-input:disabled {
    border: none;
    background: transparent;
    color: $text-disabled;
    text-opacity: 100%;
}

ChatOverlay #chat-overlay-bottom Button:focus,
ChatOverlay #chat-overlay-bottom Select:focus > SelectCurrent {
    border: round $primary;
    background: $surface;
    tint: $primary 8%;
}

ChatOverlay.has-content #chat-overlay-empty-state {
    display: none;
}

ChatOverlay.has-content #chat-overlay-output {
    display: block;
}

/* =============================================================================
   PLUGIN FORM MODAL
   ============================================================================= */

PluginFormModal {
    align: center middle;
}

PluginFormModal #dialog {
    width: 60;
    height: auto;
    border: round $primary;
    background: $surface;
    padding: 2 3;
}

PluginFormModal .dialog-title {
    text-align: center;
    text-style: bold;
    color: $primary;
    padding-bottom: 1;
}

PluginFormModal .field {
    height: auto;
    margin: 1 0 0 0;
}

PluginFormModal .field-label {
    margin-bottom: 0;
    color: $text;
    text-style: bold;
}

PluginFormModal #dialog-actions {
    height: auto;
    margin-top: 2;
    align: center middle;
}

PluginFormModal #dialog-actions Button {
    margin: 0 1;
    min-width: 16;
}

/* =============================================================================
   DON DRAPER EDITORIAL POLISH
   =============================================================================
   Intent:
   - Strong hierarchy
   - Cleaner contrast and rhythm
   - Obvious, elegant keyboard affordances
*/

/* Core interaction language */
Button {
    border: round $border;
    background: $panel;
    color: $text;
}

Button:hover {
    tint: $primary 12%;
}

Button:focus {
    border: round $primary;
    background: $surface;
    tint: $primary 8%;
    text-style: bold;
}

Button:disabled {
    color: $text-disabled;
    text-opacity: 100%;
    background: $surface;
    border: round $border;
}

Input,
TextArea {
    background: $background;
    color: $text;
    border: solid $border;
}

Select > SelectCurrent {
    background: $background;
    color: $text;
    border: solid $border;
}

Input:focus,
TextArea:focus {
    background: $surface;
    border: solid $primary;
    tint: $primary 6%;
}

Select:focus > SelectCurrent {
    background: $surface;
    border: solid $primary;
    tint: $primary 6%;
}

Input:disabled,
TextArea:disabled {
    background: $surface;
    color: $text-disabled;
    text-opacity: 100%;
    border: solid $border;
}

Select:disabled > SelectCurrent {
    background: $surface;
    color: $text-disabled;
    text-opacity: 100%;
    border: solid $border;
}

TextArea.-read-only {
    background: $surface;
    color: $text-muted;
    border: solid $warning 35%;
}

TextArea.-read-only:focus {
    border: solid $warning;
    tint: $warning 6%;
}

Tabs:focus .underline--bar {
    background: $primary;
}

Tab.-active {
    background: $primary 20%;
    color: $text;
    text-style: bold;
}

Tabs:focus .-active {
    background: $primary;
    color: $background;
    text-style: bold;
}

Tab:disabled {
    color: $text-disabled;
    text-opacity: 100%;
}

OptionList {
    background: $surface;
    color: $text;
}

OptionList:focus {
    background-tint: $primary 6%;
}

OptionList > .option-list--option-disabled {
    color: $text-disabled;
    text-opacity: 100%;
}

OptionList > .option-list--option-highlighted {
    background: $primary 24%;
    color: $text;
    text-style: bold;
}

OptionList:focus > .option-list--option-highlighted {
    background: $primary;
    color: $background;
    text-style: bold;
}

OptionList > .option-list--option-hover {
    background: $panel;
}

OptionList:disabled {
    color: $text-disabled;
    text-opacity: 100%;
}

DataTable {
    background: $surface;
    color: $text;
}

DataTable:focus {
    background-tint: $primary 6%;
}

DataTable > .datatable--header {
    background: $panel;
    color: $text;
    text-style: bold;
}

DataTable > .datatable--fixed {
    background: $panel;
    color: $text-muted;
}

DataTable > .datatable--even-row {
    background: $background 30%;
}

DataTable > .datatable--cursor,
DataTable > .datatable--fixed-cursor {
    background: $primary 24%;
    color: $text;
    text-style: bold;
}

DataTable:focus > .datatable--cursor,
DataTable:focus > .datatable--fixed-cursor {
    background: $primary;
    color: $background;
}

DataTable > .datatable--header-cursor {
    background: $primary 24%;
    color: $text;
    text-style: bold;
}

DataTable:focus > .datatable--header-cursor {
    background: $primary;
    color: $background;
}

DataTable > .datatable--header-hover,
DataTable > .datatable--hover {
    background: $panel;
}

DataTable:disabled {
    color: $text-disabled;
    text-opacity: 100%;
}

/* StartupErrorScreen fallback path should remain usable even before app boots fully. */
StartupErrorScreen {
    align: center middle;
}

#startup-error-container {
    width: 92;
    max-width: 96%;
    height: auto;
    max-height: 85%;
    background: $surface;
    border: round $error;
    padding: 1 2;
}

#startup-error-title {
    width: 100%;
    text-align: center;
    text-style: bold;
    color: $error;
    padding-bottom: 1;
}

#startup-error-guidance {
    width: 100%;
    color: $text-muted;
    padding-bottom: 1;
}

#startup-error-details {
    width: 100%;
    height: auto;
    background: $background;
    border: round $border;
    padding: 0 1;
    margin-bottom: 1;
}

#startup-error-label {
    width: 100%;
    color: $text-muted;
    text-style: bold;
}

#startup-error-message {
    width: 100%;
    color: $text;
    background: $panel;
    border: round $border;
    padding: 0 1;
}

#startup-error-actions {
    width: 100%;
    height: auto;
    align: center middle;
}

#startup-error-actions Button {
    margin: 0 1;
    min-width: 18;
}

#startup-error-retry:focus,
#startup-error-restart:focus,
#startup-error-quit:focus {
    border: round $primary;
    text-style: bold;
    tint: $primary 8%;
}

/* Editorial chrome */
KaganHeader {
    background: $panel;
    border-bottom: solid $border;
}

KaganHeader .header-title {
    color: $text;
    text-style: bold;
    text-opacity: 100%;
}

KaganHeader .header-agent,
KaganHeader .header-stats {
    color: $text-muted;
    text-opacity: 100%;
}

Footer {
    background: $panel;
    border-top: solid $border;
}

KeybindingHint,
KanbanHintBar {
    background: $panel;
}

KeybindingHint {
    border-top: solid $border;
    color: $text-muted;
}

KanbanHintBar {
    border-top: solid $border;
}

KanbanHintBar .hint-nav-center,
KanbanHintBar .hint-global {
    color: $text-disabled;
}

/* Board composition and card scan-ability */
KanbanColumn .column-header {
    background: $panel;
    border-bottom: solid $primary;
}

TaskCard {
    border-left: solid $surface;
}

TaskCard:hover {
    background: $panel;
}

TaskCard:focus {
    border-left: thick $primary;
    border-bottom: solid $primary;
    background: $panel;
}

TaskCard .card-title {
    text-style: bold;
}

TaskCard .card-desc {
    color: $text-muted;
}

/* Streaming conversation clarity */
.plan-entry,
.tool-call {
    border: round $border;
    padding: 0 1;
    margin-bottom: 1;
    background: $surface;
    background-tint: 3%;
}

.plan-entry:focus,
.tool-call:focus {
    border: round $primary;
    background-tint: 10%;
}

.plan-entry:hover,
.tool-call:hover {
    tint: $primary 8%;
}

ToolCallHeader {
    border-bottom: solid $border;
}

/* Status + hint bars read like calm instrumentation */
StatusBar {
    background: $background;
    border-top: solid $border;
}

.status-left {
    color: $text;
    text-style: bold;
}

.status-right {
    color: $text-muted;
}

/* Decision surfaces */
.permission-prompt,
.plan-approval,
WorkspaceReposWidget {
    background: $surface;
    border: round $border;
}

.permission-prompt:focus,
.plan-approval:focus,
WorkspaceReposWidget:focus {
    border: round $primary;
    background: $panel;
}

.plan-approval .plan-header,
WorkspaceReposWidget .section-header {
    color: $text;
    text-style: bold;
}

.plan-approval .plan-hint,
WorkspaceReposWidget .workspace-repos-hint {
    color: $text-muted;
}

WorkspaceRepoItem.selected .repo-item {
    background: $primary 16%;
    border-left: thick $primary;
}

WorkspaceReposWidget .repo-name.has-changes {
    color: $warning;
    text-style: bold;
}

WorkspaceReposWidget .repo-name.no-changes {
    color: $text-muted;
}

WorkspaceReposWidget .btn-diff:focus,
WorkspaceReposWidget .btn-merge:focus,
#offline-actions Button:focus,
.plan-approval #approval-buttons Button:focus {
    background: $primary;
    color: $background;
    text-style: bold;
}

/* Calm urgency for outage messaging */
OfflineBanner {
    background: $panel;
    border-bottom: solid $warning;
}

OfflineBanner:focus {
    border-bottom: solid $primary;
}

#offline-title {
    color: $warning;
    text-style: bold;
}

#offline-message {
    color: $text;
}

/* Keyboard hints remain visible but quieter than content */
.modal-keyboard-hint,
.modal-action-hint {
    color: $text-muted;
    text-opacity: 100%;
}

/* =============================================================================
   FIVE-SCREEN UX REFINEMENTS (CONSOLE-FIRST)
   ============================================================================= */

/* Header hierarchy: keep active AI and mode prominent, dim secondary metadata. */
KaganHeader .header-github-status,
KaganHeader .header-branch,
KaganHeader .header-sessions,
KaganHeader .header-separator {
    color: $text-disabled;
    text-opacity: 100%;
}

KaganHeader .header-agent {
    color: $text;
    text-style: bold;
    text-opacity: 100%;
}

KaganHeader .header-stats {
    color: $text-muted;
    text-opacity: 100%;
}

#header-help {
    color: $text-muted;
    text-opacity: 100%;
    padding-left: 1;
}

/* Console command rail as the primary action surface. */
ChatOverlay #chat-overlay-bottom {
    background: $panel;
    border-top: solid $border;
    padding: 0 1 1 1;
}

ChatOverlay #chat-overlay-command-line {
    background: $surface;
    border: round $panel;
    min-height: 3;
    max-height: 6;
    padding: 0 1;
}

ChatOverlay #chat-overlay-command-line:focus-within {
    border: round $primary;
    background: $surface;
    tint: $primary 6%;
}

ChatOverlay #chat-overlay-input-prompt {
    color: $primary;
}

ChatOverlay #chat-overlay-status .status-right {
    color: $text-disabled;
}

/* Improve long-response readability in stream output. */
StreamingOutput {
    padding: 1 2 1 2;
}

.user-input,
.agent-response,
.agent-thought {
    margin-bottom: 1;
    padding: 0 1 0 2;
}

.agent-response {
    border-left: thick $panel;
}

.agent-thought {
    border-left: thick $border;
    color: $text-muted;
}

.user-input {
    border-left: thick $primary;
    background: $panel;
}

.plan-entry,
.tool-call {
    border: round $border;
    background: $surface;
    margin-bottom: 1;
    padding: 0 1;
}

.streaming-note.error {
    color: $error;
    text-opacity: 100%;
}

.streaming-note.warning {
    color: $warning;
    text-opacity: 100%;
}

/* Muted toast severity styles (non-aggressive warnings/errors). */
ToastRack {
    align: right top;
}

Toast {
    background: $surface;
    border: round $border;
    color: $text;
}

Toast.-information {
    border: round $primary 45%;
}

Toast.-warning {
    border: round $warning 45%;
}

Toast.-error {
    border: round $error 45%;
}

Toast .toast--title {
    color: $text-muted;
}

Toast .toast--message {
    color: $text;
}

/* Task details: reduce separators, rely on spacing and softer badges. */
TaskDetailsModal #task-details-container {
    padding: 1 2 0 2;
}

TaskDetailsModal Rule {
    margin: 0;
    color: $panel;
    text-opacity: 100%;
}

TaskDetailsModal .section-title {
    color: $text;
    text-style: bold;
}

TaskDetailsModal .task-title {
    padding: 0;
    background: transparent;
    color: $text;
    text-style: bold;
}

TaskDetailsModal .task-description {
    padding: 1;
    background: $background 45%;
    border: round $border;
}

TaskDetailsModal .badge {
    padding: 0 1;
    margin-right: 1;
    height: 1;
    min-height: 1;
    border: none;
    text-opacity: 100%;
    text-style: bold;
}

TaskDetailsModal .badge-priority-high {
    background: $priority-high;
    color: $priority-high-text;
}

TaskDetailsModal .badge-priority-medium {
    border: none;
}

TaskDetailsModal .badge-priority-low {
    border: none;
}

TaskDetailsModal .badge-status {
    border: none;
}

TaskDetailsModal .badge-type,
TaskDetailsModal .badge-agent {
    border: none;
}

TaskDetailsModal .description-header,
TaskDetailsModal .workspace-repos-section,
TaskDetailsModal .github-section,
TaskDetailsModal .meta-row,
TaskDetailsModal .resume-context-section {
    margin-top: 1;
}

TaskDetailsModal .workspace-repos-section,
TaskDetailsModal .github-section {
    padding: 0;
}

TaskDetailsModal .section-header-row {
    width: 100%;
    height: auto;
    align: left middle;
}

TaskDetailsModal #workspace-repos-loading {
    padding: 0 1;
    color: $text-muted;
}

TaskDetailsModal #workspace-repos-loading.workspace-empty-state {
    color: $text-muted;
    text-style: italic;
    padding: 0 1;
}

TaskDetailsModal #github-context-content {
    color: $text-muted;
    padding: 0 1;
}

TaskDetailsModal .connect-github {
    width: auto;
    min-width: 16;
    background: $panel;
    border: round $border;
    color: $text;
}

TaskDetailsModal .connect-github:hover,
TaskDetailsModal .connect-github:focus {
    border: round $primary;
    background: $primary 12%;
    color: $text;
}

TaskDetailsModal .expand-action {
    width: auto;
    border: none;
    background: transparent;
    color: $primary;
    padding: 0 1;
}

TaskDetailsModal .expand-action:hover,
TaskDetailsModal .expand-action:focus {
    border: round $primary;
    background: $primary 12%;
    color: $text;
}

TaskDetailsModal.editing #title-input {
    text-style: bold;
    background: $panel;
    border: tall $border;
    padding: 0 1;
}

TaskDetailsModal.editing #title-input:focus {
    border: tall $primary;
    background: $surface;
}

TaskDetailsModal.editing Select {
    background: transparent;
    border: none !important;
    color: $text;
}

TaskDetailsModal.editing Select:hover > SelectCurrent,
TaskDetailsModal.editing Select:focus > SelectCurrent {
    border: none !important;
    background: $primary 12%;
}

TaskDetailsModal.editing #ac-input {
    background: $background;
    border: solid $border;
}

TaskDetailsModal.editing #ac-input:focus {
    border: solid $primary;
    background: $surface;
}

TaskDetailsModal .modal-action-hint-row .modal-action-hint-end {
    text-align: right;
}

/* Settings: compact two-pane layout inspired by toad/textual patterns. */
#settings-container {
    width: 92%;
    max-width: 112;
    min-width: 76;
    max-height: 90%;
    padding: 1 2 0 2;
    background: $surface;
    border: round $primary;
    overflow: hidden;
}

SettingsModal .modal-title {
    text-align: left;
    color: $text;
    text-style: bold;
    border-bottom: solid $border;
    padding-bottom: 1;
}

#settings-search {
    margin-top: 1;
    margin-bottom: 0;
    background: $panel;
    border: round $border;
}

#settings-search:focus {
    border: round $primary;
    background: $surface;
}

#settings-search-status {
    height: auto;
    min-height: 1;
    color: $text-muted;
    padding: 0 1 0 0;
    margin-top: 0;
    margin-bottom: 1;
    display: none;
}

#settings-workspace {
    width: 100%;
    height: 1fr;
    min-height: 0;
}

#settings-nav-pane {
    width: 28;
    min-width: 24;
    max-width: 32;
    height: 1fr;
    min-height: 0;
    border-right: solid $border;
    padding: 0 1 0 0;
}

SettingsModal .settings-nav-title {
    color: $text-muted;
    text-style: bold;
    margin-bottom: 1;
}

#settings-nav {
    width: 100%;
    height: 1fr;
    min-height: 0;
    background: transparent;
}

#settings-nav > .option-list--option {
    padding: 0 1;
    color: $text-muted;
}

#settings-nav > .option-list--option-highlighted {
    background: $primary 28%;
    color: $text;
}

#settings-nav:focus > .option-list--option-highlighted {
    background: $primary;
    color: $background;
    text-style: bold;
}

#settings-sections {
    width: 1fr;
    height: 1fr;
    min-height: 0;
    padding-left: 1;
}

SettingsModal .settings-pane {
    width: 100%;
    height: auto;
    min-height: 0;
    display: none;
    padding: 0 0 1 0;
}

SettingsModal .settings-pane.active-pane {
    display: block;
}

SettingsModal .settings-pane-title {
    width: 100%;
    color: $text;
    text-style: bold;
    margin: 0;
    padding: 0 0 1 0;
}

SettingsModal .settings-pane-empty {
    width: 100%;
    color: $text-muted;
    text-style: italic;
    margin-bottom: 1;
    display: none;
}

SettingsModal Checkbox.setting-row {
    width: 100%;
    height: auto;
    min-height: 1;
    margin-bottom: 1;
}

SettingsModal .settings-input-row {
    width: 100%;
    height: auto;
}

SettingsModal .input-group {
    width: 100%;
    height: auto;
    margin-bottom: 1;
}

SettingsModal .input-group-half {
    width: 1fr;
    margin-right: 1;
}

SettingsModal .input-group-half:last-child {
    margin-right: 0;
}

SettingsModal .input-label {
    color: $text-muted;
    margin-bottom: 0;
}

SettingsModal Input,
SettingsModal Select > SelectCurrent {
    width: 100%;
    background: $panel;
    border: round $border;
    color: $text;
}

SettingsModal Input:focus,
SettingsModal Select:focus > SelectCurrent {
    border: round $primary;
    background: $surface;
}

SettingsModal PersonaField {
    min-height: 4;
    height: auto;
    background: $panel-darken-1;
    color: $text;
    border: round $border;
    padding: 1;
}

SettingsModal PersonaField:hover {
    background: $panel;
}

SettingsModal PersonaField:focus {
    border: round $primary;
    background: $surface;
}

SettingsModal .modal-action-hint-row {
    margin-top: 0;
    padding: 0 1;
    height: 1;
    border-top: solid $border;
    background: $surface;
}

SettingsModal #settings-action-hint {
    width: 100%;
    text-align: center;
    color: $text-disabled;
    text-wrap: nowrap;
}

/* Help modal: search-first flow, stronger active tabs, strict key/action grid. */
#help-container {
    padding: 1 2 0 2;
}

#help-search-input {
    margin-bottom: 1;
    background: $panel;
    border: round $border;
}

#help-search-input:focus {
    border: round $primary;
    background: $surface;
}

#help-tabs Tabs {
    width: 100%;
    margin-bottom: 1;
}

#help-tabs Tabs:focus .underline--bar {
    background: $primary 40%;
}

#help-tabs Tab {
    color: $text-muted;
    background: transparent;
    padding: 0 1;
}

#help-tabs Tab:hover {
    color: $text;
}

#help-tabs Tab.-active {
    color: $text;
    text-style: bold;
    background: $panel;
    border: none;
}

#help-tabs Tabs:focus Tab.-active {
    color: $text;
    background: $primary 24%;
}

#help-tabs Tabs:focus .-active {
    color: $text;
    background: $primary 24%;
}

.help-section-title {
    text-style: bold;
    color: $text;
    padding-top: 1;
    padding-bottom: 0;
}

.help-subsection {
    text-style: bold;
    color: $text-muted;
    padding-top: 1;
}

.help-key-row {
    width: 100%;
    height: auto;
    min-height: 1;
    padding: 0;
}

.help-key {
    width: 22;
    min-width: 22;
    color: $text-muted;
    text-opacity: 100%;
    padding-right: 1;
    text-overflow: ellipsis;
}

.help-key-separator {
    width: 1;
    min-width: 1;
    color: $border;
}

.help-desc {
    width: 1fr;
    color: $text;
    padding-left: 1;
}

/* === Diff Browser Widget === */
DiffBrowserWidget {
    height: auto;
    min-height: 14;
}

DiffBrowserWidget > Horizontal {
    height: auto;
    min-height: 14;
}

DiffFileTree {
    width: 30%;
    min-width: 22;
    height: auto;
    min-height: 12;
    border: solid $border;
    border-right: solid $primary;
    padding: 0 1;
    overflow-y: auto;
}

DiffFileTree:focus {
    border: solid $primary;
    border-right: solid $primary;
}

DiffFileTree .diff-tree-repo-header {
    color: $text;
    text-style: bold;
    padding: 0 0 0 0;
}

DiffFileTree .diff-tree-repo-header.no-changes {
    color: $text-muted;
    text-style: none;
}

DiffFileTree .diff-tree-file-row {
    color: $text-muted;
    padding: 0 0 0 2;
}

DiffFileTree .diff-tree-file-row.cursor {
    background: $primary 20%;
    color: $text;
}

DiffFileTree .diff-tree-file-row.modified {
    color: $warning;
}

DiffFileTree .diff-tree-file-row.added {
    color: $success;
}

DiffFileTree .diff-tree-file-row.deleted {
    color: $error;
}

DiffFileTree .diff-tree-hint {
    color: $text-muted;
    text-style: italic;
    padding: 1 0 0 0;
}

DiffContentPane {
    width: 1fr;
    height: auto;
    min-height: 12;
    border: solid $border;
    padding: 0;
}

DiffContentPane:focus {
    border: solid $primary;
}

DiffContentPane .diff-content-header {
    color: $text;
    text-style: bold;
    background: $surface;
    padding: 0 1;
    height: 1;
}

DiffContentPane .diff-content-body {
    padding: 0 1;
    height: auto;
    min-height: 8;
}

DiffContentPane .diff-action-hint {
    color: $text-muted;
    background: $surface;
    padding: 0 1;
    height: 1;
}

TaskDetailsModal .diff-browser-section {
    margin-top: 1;
    padding: 0;
}
